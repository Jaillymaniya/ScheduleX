@rendermode InteractiveServer
@page "/login"

<link href="css/login.css" rel="stylesheet" />

@using Microsoft.EntityFrameworkCore
@using ScheduleX.Infrastructure.Data

@inject IDbContextFactory<AppDbContext> DbFactory
@inject ScheduleX.Web.Services.AuthState Auth
@inject ScheduleX.Web.Services.PasswordHasher Hasher
@inject NavigationManager Nav

<div class="auth-container">

    <!-- LEFT BRAND PANEL -->
    <div class="auth-left">
        <h1>ScheduleX</h1>
        <h3>Timetable Generator</h3>
        <p>
            Smart academic scheduling for institutions, faculty,
            and students — fast, accurate, and automated.
        </p>
    </div>

    <!-- RIGHT LOGIN PANEL -->
    <div class="auth-right">
        <div class="login-card">

            <h2>Sign in</h2>
            <p class="subtitle">Access your ScheduleX dashboard</p>

            <input class="input"
                   placeholder="Username"
                   @bind="Username"
                   @oninput="ClearMessages" />

            @if (showUserError)
            {
                <div class="field-error">Username is required</div>
            }

            <input type="password"
                   class="input"
                   placeholder="Password"
                   @bind="Password"
                   @oninput="ClearMessages" />

            @if (showPassError)
            {
                <div class="field-error">Password is required</div>
            }

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="server-error">@Error</div>
            }

            <button class="btn primary"
                    disabled="@_busy"
                    @onclick="DoLogin">
                @(_busy ? "Signing in..." : "Sign in")
            </button>

            <div class="forgot">
                <a href="/forgot-password">Forgot password?</a>
            </div>

        </div>
    </div>

</div>

@code {

    private string Username = "";
    private string Password = "";
    private string Error = "";
    private bool _busy;

    private bool showUserError;
    private bool showPassError;

    private async Task DoLogin()
    {
        ClearMessages();

        if (string.IsNullOrWhiteSpace(Username))
            showUserError = true;

        if (string.IsNullOrWhiteSpace(Password))
            showPassError = true;

        if (showUserError || showPassError)
            return;

        if (_busy) return;
        _busy = true;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            // 🔥 FORCE CASE-SENSITIVE COMPARISON (even if DB is CI)
            var user = await db.Users
                .AsNoTracking()
                .FirstOrDefaultAsync(u =>
                    EF.Functions.Collate(
                        u.Username,
                        "SQL_Latin1_General_CP1_CS_AS"
                    ) == Username
                    && u.IsActive);

            // 🔐 COMMON MESSAGE FOR BOTH CASES
            if (user == null || !Hasher.Verify(Password, user.PasswordHash ?? ""))
            {
                Error = "Invalid credentials.";
                return;
            }

            Auth.SignIn(user.UserId, user.FullName, user.Role);


            Nav.NavigateTo(
                user.Role == UserRole.Admin
                    ? "/admin/overview"
                    : "/tt/overview");
            // Nav.NavigateTo(user.Role == UserRole.Admin ? "/admin/overview" : "/tt/overview", forceLoad: true);
            Nav.NavigateTo(user.Role == UserRole.Admin ? "/admin/overview" : "/tt/overview", replace: true);
        }
        catch (Exception ex)
        {
            Error = ex.Message;

        }
        finally
        {
            _busy = false;
        }
    }
    private void ClearMessages(ChangeEventArgs? e = null)
    {
        showUserError = false;
        showPassError = false;
        Error = "";
    }
}