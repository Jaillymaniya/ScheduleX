@page "/tt/view"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

@using ScheduleX.Web.DTOs
@using ScheduleX.Core.Entities
@using ScheduleX.Web.Models.Template

@inject ScheduleX.Web.Services.AuthState Auth
@inject ScheduleX.Core.Interfaces.TTCoordinator.ITimetableRepository Repo
@inject ScheduleX.Web.Services.TimeTable.ITimeTableService TTService
@inject IJSRuntime JS

<link href="css/tt-view.css" rel="stylesheet" />

<div class="generate-page">

    <div class="page-header">
        <h3>View Timetable</h3>
    </div>

    <!-- ================= CARDS ================= -->
    <div class="tt-wrapper">
        <div class="tt-grid">
            @foreach (var batch in batches)
            {
                <div class="tt-card" @onclick="() => LoadPreview(batch.BatchId)">
                    <div class="tt-top">
                        <h6>@batch.Course?.CourseName</h6>
                        <span class="tt-version">@($"v{batch.VersionNo}")</span>
                    </div>
                <div class="tt-card">

                    <!-- CLICK AREA -->
                    <div @onclick="() => LoadPreview(batch.BatchId)">

                        <div class="tt-top">
                            <h6>@batch.Course?.CourseName</h6>
                            <span class="tt-version">
                                @($"v{batch.VersionNo}")
                            </span>

                        </div>

                        <div class="tt-body">
                            <div class="tt-row">
                                <span>Sem</span>
                                <b>
                                    @string.Join(", ",
                                             batch.BatchSemesters.Select(s => s.Semester.SemesterNo))
                                </b>
                            </div>
                    <div class="tt-body">
                        <div class="tt-row">
                            <span>Sem</span>
                            <b>@string.Join(", ", batch.BatchSemesters.Select(s => s.Semester.SemesterNo))</b>
                        </div>

                            <div class="tt-row">
                                <span>Date</span>
                                <b>@batch.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</b>
                            </div>
                        </div>

                        <div class="tt-footer">
                            <span class="status">@batch.Status</span>
                        </div>

                    </div>

                    <!-- DELETE BUTTON -->
                    <button class="delete-btn"
                            @onclick="() => OpenDeletePopup(batch.BatchId)"
                            @onclick:stopPropagation="true">
                        🗑
                    </button>

                </div>
                    <div class="tt-footer">
                        <span class="status">@batch.Status</span>
                    </div>
                </div>
            }
        </div>
    </div>
    @if (showDeletePopup)
    {
        <div class="popup-overlay">
            <div class="popup-box">

                <h4>Delete Timetable</h4>
                <p>Are you sure you want to delete this timetable permanently?</p>

                <div class="popup-actions">
                    <button class="btn-cancel" @onclick="ClosePopup">Cancel</button>
                    <button class="btn-delete" @onclick="DeleteConfirmed">Delete</button>
                </div>

            </div>
        </div>
    }
    <!-- ================= DIVISION SELECTOR ================= -->
    @if (divisions.Any())
    {
        <div style="margin-top:20px;">
            @foreach (var div in divisions)
            {
                <button class="btn btn-primary"
                        style="margin-right:10px;
                        background:@(selectedDivision == div ? "#22c55e" : "#2563eb")"
                        @onclick="() => SelectDivision(div)">
                    @div
                </button>
            }
        </div>
    }

    <!-- ================= PREVIEW ================= -->
    @if (filteredData.Any())
    {
        <div class="preview-card">

            <h5 style="text-align:@style.titleAlign">
                Division: @selectedDivision
            </h5>

            <table style="width:100%; border-collapse:collapse; font-size:@style.fontSize">

                <thead style="background:@style.headerBg; color:@style.headerText;">
                    <tr>
                        <th>Time</th>
                        @foreach (var day in days)
                        {
                            <th>@GetDayName(day)</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @foreach (var slot in slots)
                    {
                        <tr>
                            <td><b>Slot @slot</b></td>

                            @foreach (var day in days)
                            {
                                var cell = filteredData
                                .FirstOrDefault(x => x.Day == day && x.Slot == slot);

                                <td style="
                                    padding:@style.cellPadding;
                                    border:1px solid @style.borderColor;
                                    cursor:pointer;
                                    background:@(
                                        cell?.EntryId == errorCellId ? "#fca5a5" :
                                        cell?.EntryId == firstSelectedCell?.EntryId ? "#fde68a" :
                                        style.bodyBg
                                    );"
                                    @onclick="() => SelectCell(cell)">

                                    @if (cell != null && cell.Subject != "Free")
                                    {
                                        <div><b>@cell.Subject</b></div>

                                        @if (style.showFaculty)
                                        {
                                            <small>@cell.Faculty</small>
                                        }

                                        @if (style.showRoom)
                                        {
                                            <div>@cell.Room</div>
                                        }
                                    }
                                    else
                                    {
                                        <span>Free</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>

            <br />

            <!-- BUTTONS -->
            <div class="d-flex gap-2">
                <button class="btn btn-info"
                        @onclick="ToggleSwapMode">
                    @(isSwapMode ? "Cancel Shuffle" : "Shuffle Timetable")
                </button>

                <button class="btn btn-primary" @onclick="Download">
                    Download Excel
                </button>
            </div>

            <!-- ERROR MESSAGE -->
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="color:red; font-weight:bold; margin-top:10px;">
                    @errorMessage
                </div>
            }

        </div>
    }
</div>

@code {

    List<TimeTableBatch> batches = new();
    List<PreviewDto> previewData = new();
    List<PreviewDto> filteredData = new();

    List<string> divisions = new();
    string selectedDivision;

    List<int> slots = new();
    List<int> days = new() { 1, 2, 3, 4, 5, 6 };

    string fileBase64 = "";
    TemplateStyle style = new();

    // 🔄 SWAP MODE
    bool isSwapMode = false;
    PreviewDto firstSelectedCell;

    // ❗ ERROR UI
    string errorMessage = "";
    int errorCellId = 0;

    int selectedBatchId;

    protected override async Task OnInitializedAsync()
    {
        var userId = Auth.UserId.Value;

        var all = await Repo.GetAllBatches();

        batches = all
            .Where(x => x.CreatedByUserId == userId)
            .OrderByDescending(x => x.CreatedAt)
            .ToList();
    }

    async Task LoadPreview(int batchId)
    {
        var result = await TTService.GetPreviewByBatch(batchId);

        previewData = result.Preview;
        fileBase64 = result.Base64 ?? "";
        style = result.TemplateStyle ?? new TemplateStyle();

        divisions = previewData.Select(x => x.Division).Distinct().ToList();
        selectedDivision = divisions.FirstOrDefault();

        ApplyDivisionFilter();

        selectedBatchId = batchId;
    }

    void ToggleSwapMode()
    {
        isSwapMode = !isSwapMode;
        firstSelectedCell = null;
        errorMessage = "";
        errorCellId = 0;
    }

    async Task SelectCell(PreviewDto cell)
    {
        if (!isSwapMode)
            return;

        if (cell == null || cell.Subject == "Break")
            return;

        // First click
        if (firstSelectedCell == null)
        {
            firstSelectedCell = cell;
            return;
        }

        // Same cell reset
        if (firstSelectedCell.EntryId == cell.EntryId)
        {
            firstSelectedCell = null;
            return;
        }

        // Different division block
        if (firstSelectedCell.Division != cell.Division)
        {
            errorMessage = "Same division only";
            errorCellId = cell.EntryId;
            firstSelectedCell = null;
            return;
        }

        // ✅ INSTANT SWAP (await important)
        await SwapCells(firstSelectedCell, cell);

        firstSelectedCell = null;
    }

    async Task SwapCells(PreviewDto c1, PreviewDto c2)
    {
        var dto = new SwapEntryDto
            {
                EntryId1 = c1.EntryId,
                EntryId2 = c2.EntryId,
                UserId = Auth.UserId.Value
            };

        var result = await TTService.SwapEntriesAsync(dto);

        if (!result.Success)
        {
            errorMessage = result.Message;
            errorCellId = c2.EntryId;
            return;
        }

        errorMessage = "";
        errorCellId = 0;

        await LoadPreview(selectedBatchId);
    }
    void SelectDivision(string div)
    {
        selectedDivision = div;
        ApplyDivisionFilter();
    }
    int deleteBatchId;
    bool showDeletePopup = false;

    void OpenDeletePopup(int batchId)
    {
        deleteBatchId = batchId;
        showDeletePopup = true;
    }

    void ClosePopup()
    {
        showDeletePopup = false;
    }

    async Task DeleteConfirmed()
    {
        var success = await Repo.DeleteBatchAsync(deleteBatchId);

        if (success)
        {
            batches = batches.Where(x => x.BatchId != deleteBatchId).ToList();

            previewData.Clear();
            filteredData.Clear();
        }

        showDeletePopup = false;
    }
    void ApplyDivisionFilter()
    {
        filteredData = previewData
            .Where(x => x.Division == selectedDivision)
            .ToList();

        slots = filteredData
            .Select(x => x.Slot)
            .Distinct()
            .OrderBy(x => x)
            .ToList();
    }

    async Task Download()
    {
        if (string.IsNullOrEmpty(fileBase64))
            return;

        await JS.InvokeVoidAsync("downloadFileFromBase64", "timetable.xlsx", fileBase64);
    }

    string GetDayName(int day) => day switch
    {
        1 => "Mon",
        2 => "Tue",
        3 => "Wed",
        4 => "Thu",
        5 => "Fri",
        6 => "Sat",
        _ => ""
    };
}