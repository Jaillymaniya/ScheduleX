@*                                             <option value="0">Select Room</option> *@
@*                                             @foreach (var r in rooms) *@
@*                                             { *@
@*                                                 <option value="@r.RoomId">@r.RoomName</option> *@
@*                                             } *@
@*                                         </select> *@

@*                                         <button class="btn btn-success btn-sm mt-1" *@
@*                                                 @onclick="SaveEdit" *@
@*                                                 @onclick:stopPropagation="true"> *@
@*                                             Save *@
@*                                         </button> *@
@*                                     } *@
@*                                     else *@
@*                                     { *@
@*                                         @if (cell != null && cell.Subject != "Free") *@
@*                                         { *@
@*                                             <div><b>@cell.Subject</b></div> *@

@*                                             @if (style.showFaculty) *@
@*                                             { *@
@*                                                 <small>@cell.Faculty</small> *@
@*                                             } *@

@*                                             @if (style.showRoom) *@
