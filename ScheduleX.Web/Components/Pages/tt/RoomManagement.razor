@page "/tt/room-management"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

@using ScheduleX.Core.Entities
@using ScheduleX.Core.Interfaces.TTCoordinator

@inject IRoomRepository RoomRepo

<div class="room-page">
    <h3 class="mb-4">Room / Lab Management</h3>

    <!-- ================= FORM ================= -->
    <div class="tt-card">

        <h5 class="mb-4">Add Room</h5>

        <div class="tt-form-row">

            <div class="tt-form-group">
                <label>Room Name</label>
                <input class="tt-input" @bind="room.RoomName" />
            </div>

            <div class="tt-form-group">
                <label>Room Type</label>
                <select class="tt-select" @bind="room.RoomType">
                    <option value="0">-- Select Type --</option>
                    <option value="@RoomTypeEnum.Classroom">Classroom</option>
                    <option value="@RoomTypeEnum.Lab">Lab</option>
                </select>
            </div>

        </div>

        <div class="tt-form-row">

            <div class="tt-form-group">
                <label>Capacity</label>
                <input type="number" class="tt-input" @bind="room.Capacity" />
            </div>

            <div class="tt-form-group">
                <label>Department</label>
                <select class="tt-select" @bind="room.DepartmentId">
                    <option value="0">-- Select Department --</option>

                    @foreach (var d in departments)
                    {
                        <option value="@d.DepartmentId">@d.DepartmentName</option>
                    }
                </select>
            </div>

        </div>

        <button class="btn btn-success tt-btn"
                @onclick="SaveRoom">
            @(isEdit ? "Update Room" : "Save Room")
        </button>

    </div>

    <hr />

    <!-- ================= TABLE ================= -->
    <div class="tt-table-container">

        <table class="tt-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Capacity</th>
                    <th>Department</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var r in rooms)
                {
                    <tr class="@(r.IsActive ? "" : "inactive-row")">

                        <td>@r.RoomName</td>
                        <td>@r.RoomType</td>
                        <td>@r.Capacity</td>
                        <td>@r.Department?.DepartmentName</td>

                        <td>
                            <span class="badge @(r.IsActive ? "bg-success" : "bg-secondary")">
                                @(r.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>

                        <td>
                            <div class="action-buttons">

                                <button class="btn btn-info"
                                        disabled="@(!r.IsActive)"
                                        @onclick="() => EditRoom(r)">
                                    Edit
                                </button>

                                @if (r.IsActive)
                                {
                                    <button class="btn btn-danger"
                                            @onclick="() => DeactivateRoom(r.RoomId)">
                                        Deactivate
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-success"
                                            @onclick="() => ActivateRoom(r.RoomId)">
                                        Activate
                                    </button>
                                }

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

<!-- 🔥 TOAST -->
@if (showToast)
{
    <div class="toast-container">
        <div class="toast-message @toastType">
            <span>@toastMessage</span>
            <div class="toast-progress"></div>
        </div>
    </div>
}

@code {

    private Room room = new();
    private List<Room> rooms = new();
    private List<Department> departments = new();

    private bool isEdit = false;

    // 🔥 TOAST
    bool showToast = false;
    string toastMessage = "";
    string toastType = "success";

    protected override async Task OnInitializedAsync()
    {
        departments = await RoomRepo.GetDepartmentsAsync();
        rooms = await RoomRepo.GetAllRoomsAsync();
    }

    // 🔥 TOAST METHOD
    async Task ShowToast(string message, string type = "success")
    {
        toastMessage = message;
        toastType = type;
        showToast = true;

        StateHasChanged();

        await Task.Delay(3000);

        showToast = false;
        StateHasChanged();
    }

    private async Task SaveRoom()
    {
        // 🔴 REQUIRED VALIDATION
        if (string.IsNullOrWhiteSpace(room.RoomName))
        {
            await ShowToast("Room Name is required", "danger");
            return;
        }

        if (room.RoomType == 0)
        {
            await ShowToast("Room Type is required", "danger");
            return;
        }

        if (room.Capacity <= 0)
        {
            await ShowToast("Capacity is required", "danger");
            return;
        }

        if (room.DepartmentId == 0)
        {
            await ShowToast("Department is required", "danger");
            return;
        }

        // 🔴 UNIQUE ROOM NAME
        if (rooms.Any(r => r.RoomName.ToLower() == room.RoomName.ToLower()
            && (!isEdit || r.RoomId != room.RoomId)))
        {
            await ShowToast("Room name already exists", "danger");
            return;
        }

        // ✅ SAVE / UPDATE
        if (isEdit)
        {
            await RoomRepo.UpdateRoomAsync(room);
            await ShowToast("Room Updated Successfully", "info");
        }
        else
        {
            await RoomRepo.AddRoomAsync(room);
            await ShowToast("Room Added Successfully", "success");
        }

        room = new Room();
        isEdit = false;

        rooms = await RoomRepo.GetAllRoomsAsync();
    }

    private void EditRoom(Room r)
    {
        if (!r.IsActive) return;

        room = new Room
            {
                RoomId = r.RoomId,
                RoomName = r.RoomName,
                RoomType = r.RoomType,
                Capacity = r.Capacity,
                DepartmentId = r.DepartmentId
            };

        isEdit = true;
    }

    private async Task DeactivateRoom(int id)
    {
        await RoomRepo.DeactivateRoomAsync(id);
        await ShowToast("Room Deactivated", "danger");

        rooms = await RoomRepo.GetAllRoomsAsync();
    }

    private async Task ActivateRoom(int id)
    {
        await RoomRepo.ActivateRoomAsync(id);
        await ShowToast("Room Activated", "success");

        rooms = await RoomRepo.GetAllRoomsAsync();
    }
}