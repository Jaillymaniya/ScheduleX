@page "/tt/subject-semester"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

@using System.Text
@using ScheduleX.Core.Entities
@using ScheduleX.Core.Interfaces.TTCoordinator
@using SubjectSemesterEntity = ScheduleX.Core.Entities.SubjectSemester
@inject ScheduleX.Web.Services.AuthState Auth
@inject ISubjectSemesterRepository Repo
@inject IJSRuntime JS
@inject NavigationManager Nav

<link href="css/subject-semester.css?v=2" rel="stylesheet" />

<h3 class="mb-4">Subject ↔ Semester Mapping</h3>

<button class="btn btn-secondary mb-3" @onclick="GoBack">
    ← Back
</button>



<!-- BUTTONS -->
<div class="btn-section">
    <button class="btn btn-success me-2" @onclick="ShowManual">Add Manual</button>
    <button class="btn btn-warning" @onclick="ShowCsv">Upload CSV</button>
</div>

<!-- PROGRESS -->
@if (isUploading)
{
    <div class="progress-container mb-3">
        <div class="progress-bar" style="width:@progress%"></div>
    </div>
}

<!-- ================= MANUAL FORM ================= -->
@if (showManual)
{
    <div class="tt-card p-4 mb-5">

        <EditForm Model="model" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="subject-grid">

                <!-- COURSE -->
                <div class="form-field">
                    <label>Course</label>
                    @if (!courses.Any())
                    {
                        <p class="text-warning">No courses assigned to you</p>
                    }
                    <select class="tt-select"
                            @bind="courseId"
                            @bind:after="LoadDropdowns">
                        <option value="0">Select Course</option>
                        @foreach (var c in courses)
                        {
                            <option value="@c.CourseId">@c.CourseName</option>
                        }
                    </select>
                </div>

                <!-- SEMESTER -->
                <div class="form-field">
                    <label>Semester</label>
                    <select class="tt-select" @bind="model.SemesterId">
                        <option value="0">Select Semester</option>
                        @foreach (var s in semesters)
                        {
                            <option value="@s.SemesterId">Sem @s.SemesterNo</option>
                        }
                    </select>
                </div>

                <!-- SUBJECT -->
                <div class="form-field">
                    <label>Subject</label>
                    <select class="tt-select" @bind="model.SubjectId">
                        <option value="0">Select Subject</option>
                        @foreach (var s in subjects)
                        {
                            <option value="@s.SubjectId">@s.SubjectName</option>
                        }
                    </select>
                </div>

            </div>
            <div class="btn-section">
            <button class="btn btn-success me-2">Save</button>
            <button type="button" class="btn btn-secondary" @onclick="CloseForm">Close</button>
            </div>
        </EditForm>
    </div>
}

<!-- ================= CSV ================= -->
@if (showCsv)
{
    <div class="tt-card p-4 mb-4">

        <h5>Upload CSV</h5>

        <button class="btn btn-info mb-2" @onclick="DownloadTemplate">
            Download Template
        </button>

        <InputFile OnChange="OnFileSelected" />

        <br />
        <div class="btn-section">
        <button class="btn btn-success mt-2"
                @onclick="ProcessCsv"
                disabled="@(!isFileSelected)">
            Insert Data
        </button>

        <button class="btn btn-secondary mt-2 ms-2" @onclick="CloseForm">
            Close
        </button>
        </div>
    </div>
}
<div class="section-divider"></div>
<!-- ================= TABLE ================= -->
<div class="tt-card p-3">
    <table class="table table-dark table-hover">
        <thead>
            <tr>
                <th>Course</th>
                <th>Semester</th>
                <th>Subject</th>
                <th width="120">Action</th>
            </tr>
        </thead>

        <tbody>

            @if (!list.Any())
            {
                <tr>
                    <td colspan="4" class="text-center text-warning">
                        No records found
                    </td>
                </tr>
            }
            else
            {
                <!-- ACTIVE -->
                @* <tr class="table-section"> *@
                @*     <td colspan="4">Active Records</td> *@
                @* </tr> *@

                @foreach (var item in list.Where(x => x.IsActive))
                {
                    <tr>
                        <td>@item.Semester.Course.CourseName</td>
                        <td>Semester @item.Semester.SemesterNo</td>
                        <td>@item.Subject.SubjectName</td>

                        <td>
                            <div class="action-group">

                                <button class="btn btn-sm btn-info"
                                        @onclick="() => Edit(item)">
                                     Edit
                                </button>

                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => Deactivate(item.SubjectSemesterId)">
                                     Deactivate
                                </button>

                            </div>
                        </td>
                    </tr>
                }

                <!-- INACTIVE -->
                @* <tr class="table-section"> *@
                @*     <td colspan="4">Inactive Records</td> *@
                @* </tr> *@

                @foreach (var item in list.Where(x => !x.IsActive))
                {
                    <tr class="opacity-50">
                        <td>@item.Semester.Course.CourseName</td>
                        <td>Semester @item.Semester.SemesterNo</td>
                        <td>@item.Subject.SubjectName</td>

                        <td>
                            <div class="action-group">

                                <button class="btn btn-sm btn-info"
                                        disabled>
                                     Edit
                                </button>

                                <button class="btn btn-sm btn-success"
                                        @onclick="() => Activate(item.SubjectSemesterId)">
                                     Activate
                                </button>

                            </div>
                        </td>
                    </tr>
                }
            }

        </tbody>
    </table>
</div>

