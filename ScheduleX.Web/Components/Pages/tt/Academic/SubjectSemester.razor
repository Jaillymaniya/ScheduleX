        {
            await Repo.UpdateAsync(model);
            await ShowToast("Updated successfully", "success");
        }
        else
        {
            model.SubjectSemesterId = 0;
            var result = await Repo.AddAsync(model);

            await ShowToast(result.Item2, result.Item1 ? "success" : "danger");

            if (!result.Item1) return;
        }

        var userId = Auth.UserId!.Value;
        list = await Repo.GetByCoordinatorAsync(userId);

        model = new();
        isEditMode = false;
        showManual = false;
    }

