    async Task ProcessCsv()
    {
        if (file == null) return;

        isUploading = true;
        progress = 0;

        var listCsv = new List<SubjectSemesterEntity>();

        using var reader = new StreamReader(file.OpenReadStream());

        string? line;
        bool header = true;
        int row = 1;

        // 🔥 Load ALL DATA (not course filtered)
        // var allCourses = await Repo.GetCoursesAsync(1); department based
        var userId = Auth.UserId!.Value;

        var allowedCourses = await Repo.GetCoursesForCoordinatorAsync(userId);
        var allSemesters = await Repo.GetAllSemestersAsync();
        var allSubjects = await Repo.GetAllSubjectsAsync();
        
        while ((line = await reader.ReadLineAsync()) != null)
        {
            if (header)
            {
                header = false;
                continue;
            }

            row++;

            if (string.IsNullOrWhiteSpace(line))
                continue;

            var data = line.Split(',');

            if (data.Length < 3)
            {
                await ShowToast($"Row {row}: Missing columns", "danger");
                isUploading = false;
                return;
            }

            string courseName = data[0]?.Trim() ?? "";
            string semText = data[1]?.Trim() ?? "";
            string subjectName = data[2]?.Trim() ?? "";

            // ❌ Course Validation
            // ❌ Course Validation (ACTIVE)
            var course = allowedCourses.FirstOrDefault(c =>
     c.CourseName.Trim().Equals(courseName, StringComparison.OrdinalIgnoreCase));

            if (course == null)
            {
                await ShowToast($"Row {row}: Course not allowed or inactive", "danger");
                isUploading = false;
                return;
            }

            // ❌ Semester Validation
            if (!byte.TryParse(semText, out var semNo))
            {
                await ShowToast($"Row {row}: Invalid Semester '{semText}'", "danger");
                isUploading = false;
                return;
            }

            // ❌ Semester Validation (ACTIVE + Course match)
            var sem = allSemesters.FirstOrDefault(s =>
                s.SemesterNo == semNo &&
                s.CourseId == course.CourseId);

            if (sem == null)
            {
                await ShowToast($"Row {row}: Semester '{semNo}' not active for course '{courseName}'", "danger");
                isUploading = false;
                return;
            }

            // ❌ Subject Validation
            // ❌ Subject Validation (ACTIVE + Course match)
            var sub = allSubjects.FirstOrDefault(s =>
                s.SubjectName.Trim().Equals(subjectName, StringComparison.OrdinalIgnoreCase) &&
                s.CourseId == course.CourseId);

            if (sub == null)
            {
                await ShowToast($"Row {row}: Subject '{subjectName}' not active in course '{courseName}'", "danger");
                isUploading = false;
                return;
            }

            // ❌ Duplicate check (CSV)
            if (listCsv.Any(x => x.SubjectId == sub.SubjectId && x.SemesterId == sem.SemesterId))
            {
                await ShowToast($"Row {row}: Duplicate in CSV", "warning");
                continue;
            }

            listCsv.Add(new SubjectSemesterEntity
                {
                    SemesterId = sem.SemesterId,
                    SubjectId = sub.SubjectId
                });

            progress = Math.Min(80, progress + 5);
            await Task.Delay(1);
            StateHasChanged();
        }

        if (!listCsv.Any())
        {
            await ShowToast("No valid data found", "danger");
            isUploading = false;
            return;
        }

        var result = await Repo.BulkInsertAsync(listCsv);

        progress = 100;

        await ShowToast(result.Item2, result.Item1 ? "success" : "danger");

        list = await Repo.GetAllAsync();
        isUploading = false;
    }
    private async Task DownloadTemplate()
    {
        var csv = "CourseName,SemesterNo,SubjectName\n";
        var bytes = Encoding.UTF8.GetBytes(csv);

        await JS.InvokeVoidAsync("downloadFile", "SubjectSemester.csv", bytes);
    }

    async Task ShowToast(string msg, string type)
    {
        await JS.InvokeVoidAsync("showToast", msg, type);
    }
}