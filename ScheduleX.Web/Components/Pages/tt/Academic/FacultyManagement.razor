

@* //it wrkable *@
@page "/tt/academic/faculty"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

@using ScheduleX.Core.Entities
@using ScheduleX.Core.Interfaces.TTCoordinator
@inject IFacultyRepository FacultyRepo

<link href="css/faculty.css" rel="stylesheet" />

<h3>Faculty Management</h3>

<!-- ================= FORM ================= -->
<div class="tt-card">

    <h4>Add Faculty</h4>

    <div class="form-grid-2">

        <div>
            <label>Name</label>
            <input class="tt-input" @bind="model.FacultyName" />
        </div>

        <div>
            <label>Email</label>
            <input class="tt-input" @bind="model.Email" />
        </div>

        <div>
            <label>Phone</label>
            <input class="tt-input" @bind="model.Phone" />
        </div>

        <div>
            <label>Faculty Code</label>
            <input class="tt-input" @bind="model.FacultyCode" />
        </div>

        <div>
            <label>Max Lectures</label>
            <input class="tt-input" type="number"
                   @bind-value="model.MaxLecturesPerDay"
                   @bind-value:event="oninput" />
        </div>

        <div>
            <label>Department</label>
            <select class="tt-input" @bind="model.DepartmentId">
                <option value="0">-- Select Department --</option>
                @foreach (var d in departments)
                {
                    <option value="@d.DepartmentId">@d.DepartmentName</option>
                }
            </select>
        </div>

    </div>

    <br />

    <label>
        <input type="checkbox" @bind="model.IsExternal" />
        External Faculty
    </label>

    @if (model.IsExternal)
    {
        <select class="tt-input" @bind="externalDepartmentId">
            <option value="0">-- Select External Dept --</option>
            @foreach (var d in departments)
            {
                <option value="@d.DepartmentId">@d.DepartmentName</option>
            }
        </select>
    }

    <br />

    @if (isEditMode)
    {
        <button class="btn-success" @onclick="UpdateFaculty">Update</button>
        <button class="btn-danger" @onclick="CancelEdit">Cancel</button>
    }
    else
    {
        <button class="btn-save" @onclick="SaveFaculty">Save</button>
    }

</div>

<hr />

<!-- ================= TABLE ================= -->
<div class="tt-table">

    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Code</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Dept</th>
                <th>Max Lec</th>
                
                @* <th>External</th> *@
                <th>External Dept</th>   <!-- 🔥 ADD -->
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var f in facultyList)
            {
                <tr>
                    <td>@f.FacultyName</td>
                    <td>@f.FacultyCode</td>
                    <td>@f.Email</td>
                    <td>@f.Phone</td>
                    <td>@f.Department?.DepartmentName</td>
                    <td>@f.MaxLecturesPerDay</td>
                    @* <td>@(f.IsExternal ? "Yes" : "No")</td> *@

                    <td>
                        @if (f.ExternalPermissions != null && f.ExternalPermissions.Any())
                        {
                            @string.Join(", ", f.ExternalPermissions.Select(x => x.Department.DepartmentName))
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>

                    <td>
                        <span class="status-badge @(f.IsActive ? "active" : "inactive")">
                            @(f.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>

                    <td>
                        @* <button class="btn-edit @(f.IsActive ? "" : "btn-disabled")" *@
                        @*         disabled="@(!f.IsActive)" *@
                        @*         @onclick="() => EditFaculty(f)"> *@
                        @*     Edit *@
                        @* </button> *@

                        <button class="btn-edit @(f.IsActive ? "" : "btn-edit-disabled")"
                                disabled="@(!f.IsActive)"
                                @onclick="() => EditFaculty(f)">
                            Edit
                        </button>

                        @if (f.IsActive)
                        {
                            <button class="btn-danger"
                                    @onclick="() => DeleteFaculty(f.FacultyId)">
                                Deactivate
                            </button>
                        }
                        else
                        {
                            <button class="btn-success"
                                    @onclick="() => ActivateFaculty(f.FacultyId)">
                                Activate
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

@code {

    private Faculty model = new();
    private List<Faculty> facultyList = new();
    private List<Department> departments = new();

    private int externalDepartmentId = 0;
    private bool isEditMode = false;

    protected override async Task OnInitializedAsync()
    {
        departments = await FacultyRepo.GetDepartmentsAsync();
        facultyList = await FacultyRepo.GetAllAsync();
    }

    private async Task SaveFaculty()
    {
        if (string.IsNullOrWhiteSpace(model.FacultyName))
            return;

        if (model.DepartmentId <= 0)
            return;

        await FacultyRepo.AddAsync(model);

        if (model.IsExternal && externalDepartmentId > 0)
        {
            await FacultyRepo.AddExternalPermissionAsync(
                new ExternalFacultyPermission
                    {
                        FacultyId = model.FacultyId,
                        DepartmentId = externalDepartmentId,
                        IsActive = true
                    });
        }

        ResetForm();
        await LoadData();
    }

    private void EditFaculty(Faculty f)
    {
        if (!f.IsActive)
            return;

        model = new Faculty
            {
                FacultyId = f.FacultyId,
                FacultyName = f.FacultyName,
                Email = f.Email,
                Phone = f.Phone,
                FacultyCode = f.FacultyCode,
                DepartmentId = f.DepartmentId,
                MaxLecturesPerDay = f.MaxLecturesPerDay,
                IsExternal = f.IsExternal
            };

        isEditMode = true;
    }

    // private async Task UpdateFaculty()
    // {
    //     await FacultyRepo.UpdateAsync(model);
    //     ResetForm();
    //     await LoadData();
    // }
    //iscorrect
    // private async Task UpdateFaculty()
    // {
    //     await FacultyRepo.UpdateAsync(model);

       
    //     if (model.IsExternal && externalDepartmentId > 0)
    //     {
    //         var existing = await FacultyRepo.GetExternalPermissions(model.FacultyId);

    //         if (!existing.Any())
    //         {
    //             await FacultyRepo.AddExternalPermissionAsync(
    //                 new ExternalFacultyPermission
    //                     {
    //                         FacultyId = model.FacultyId,
    //                         DepartmentId = externalDepartmentId,
    //                         IsActive = true
    //                     });
    //         }
    //     }

    //     ResetForm();
    //     await LoadData();
    // }

    private async Task UpdateFaculty()
    {
        await FacultyRepo.UpdateAsync(model);

        var existing = await FacultyRepo.GetExternalPermissions(model.FacultyId);

        if (model.IsExternal && externalDepartmentId > 0)
        {
            if (!existing.Any())
            {
                // INSERT
                await FacultyRepo.AddExternalPermissionAsync(
                    new ExternalFacultyPermission
                        {
                            FacultyId = model.FacultyId,
                            DepartmentId = externalDepartmentId,
                            IsActive = true
                        });
            }
            else
            {
                // UPDATE (direct DB update needed)
                existing[0].DepartmentId = externalDepartmentId;
            }
        }
        else
        {
            // ❌ REMOVE WITHOUT NEW METHOD
            foreach (var item in existing)
            {
                item.IsActive = false; // ✔ soft remove instead of delete
            }
        }

        ResetForm();
        await LoadData();
    }

    private void CancelEdit()
    {
        ResetForm();
    }

    private async Task DeleteFaculty(int id)
    {
        await FacultyRepo.SoftDeleteAsync(id);
        await LoadData();
    }

    private async Task ActivateFaculty(int id)
    {
        await FacultyRepo.ActivateAsync(id);
        await LoadData();
    }

    private async Task LoadData()
    {
        facultyList = await FacultyRepo.GetAllAsync();
    }

    private void ResetForm()
    {
        model = new Faculty();
        externalDepartmentId = 0;
        isEditMode = false;
    }
}