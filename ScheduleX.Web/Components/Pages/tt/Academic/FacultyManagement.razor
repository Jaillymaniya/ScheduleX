    private async Task SaveFaculty()
    {
        var ttDept = departments.FirstOrDefault(d => d.DepartmentName == "TT");

if (ttDept != null)
{
    model.DepartmentId = ttDept.DepartmentId;
}

        // 🔴 REQUIRED VALIDATION
        if (string.IsNullOrWhiteSpace(model.FacultyName))
        {
            await ShowToast("Name is required", "danger");
            return;
        }

        if (string.IsNullOrWhiteSpace(model.Email))
        {
            await ShowToast("Email is required", "danger");
            return;
        }

        if (string.IsNullOrWhiteSpace(model.Phone))
        {
            await ShowToast("Phone is required", "danger");
            return;
        }

        if (string.IsNullOrWhiteSpace(model.FacultyCode))
        {
            await ShowToast("Faculty Code is required", "danger");
            return;
        }

        if (model.DepartmentId <= 0)
        {
            await ShowToast("Department is required", "danger");
            return;
        }

        // 🔴 PHONE VALIDATION (10 digits)
        if (!System.Text.RegularExpressions.Regex.IsMatch(model.Phone, @"^\d{10}$"))
        {
            await ShowToast("Phone must be exactly 10 digits", "danger");
            return;
        }
        // 🔴 PHONE UNIQUE
        if (facultyList.Any(f => f.Phone == model.Phone))
        {
            await ShowToast("Phone number already exists", "danger");
            return;
        }

        // 🔴 EMAIL UNIQUE
        if (facultyList.Any(f => f.Email == model.Email))
        {
            await ShowToast("Email already exists", "danger");
            return;
        }

        // 🔴 FACULTY CODE UNIQUE
        if (facultyList.Any(f => f.FacultyCode == model.FacultyCode))
        {
            await ShowToast("Faculty Code already exists", "danger");
            return;
        }

        // 🔴 EXTERNAL SAME DEPT CHECK
        if (model.IsExternal && externalDepartmentId == model.DepartmentId)
        {
            await ShowToast("External department cannot be same", "danger");
            return;
        }

        // ✅ SAVE
        await FacultyRepo.AddAsync(model);

        await ShowToast("Faculty Added Successfully", "success");

        if (model.IsExternal && externalDepartmentId > 0)
        {
            await FacultyRepo.AddExternalPermissionAsync(
                new ExternalFacultyPermission
                    {
                        FacultyId = model.FacultyId,
                        DepartmentId = externalDepartmentId,
                        IsActive = true
                    });
        }

        ResetForm();
        await LoadData();
    }

