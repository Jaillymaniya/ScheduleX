    private async Task UpdateFaculty()
    {
        var ttDept = departments.FirstOrDefault(d => d.DepartmentName == "TT");

if (ttDept != null)
{
    model.DepartmentId = ttDept.DepartmentId;
}

        // 🔴 REQUIRED
        if (string.IsNullOrWhiteSpace(model.FacultyName))
        {
            await ShowToast("Name is required", "danger");
            return;
        }

        if (string.IsNullOrWhiteSpace(model.Email))
        {
            await ShowToast("Email is required", "danger");
            return;
        }

        if (string.IsNullOrWhiteSpace(model.Phone))
        {
            await ShowToast("Phone is required", "danger");
            return;
        }

        if (string.IsNullOrWhiteSpace(model.FacultyCode))
        {
            await ShowToast("Faculty Code is required", "danger");
            return;
        }

        // 🔴 PHONE
        if (!System.Text.RegularExpressions.Regex.IsMatch(model.Phone, @"^\d{10}$"))
        {
            await ShowToast("Phone must be 10 digits", "danger");
            return;
        }

        // 🔴 EMAIL UNIQUE (ignore self)
        if (facultyList.Any(f => f.Email == model.Email && f.FacultyId != model.FacultyId))
        {
            await ShowToast("Email already exists", "danger");
            return;
        }

        // 🔴 CODE UNIQUE
        if (facultyList.Any(f => f.FacultyCode == model.FacultyCode && f.FacultyId != model.FacultyId))
        {
            await ShowToast("Faculty Code already exists", "danger");
            return;
        }
        // 🔴 PHONE UNIQUE (ignore self)
        if (facultyList.Any(f => f.Phone == model.Phone && f.FacultyId != model.FacultyId))
        {
            await ShowToast("Phone number already exists", "danger");
            return;
        }

        // 🔴 EXTERNAL SAME DEPT
        if (model.IsExternal && externalDepartmentId == model.DepartmentId)
        {
            await ShowToast("External department cannot be same", "danger");
            return;
        }

        // ✅ UPDATE
        await FacultyRepo.UpdateAsync(model);

        await ShowToast("Updated Successfully", "success");

        var existing = await FacultyRepo.GetExternalPermissions(model.FacultyId);

        if (model.IsExternal && externalDepartmentId > 0)
        {
            if (!existing.Any())
            {
                await FacultyRepo.AddExternalPermissionAsync(
                    new ExternalFacultyPermission
                        {
                            FacultyId = model.FacultyId,
                            DepartmentId = externalDepartmentId,
                            IsActive = true
                        });
            }
            else
            {
                existing[0].DepartmentId = externalDepartmentId;
            }
        }
        else
        {
            foreach (var item in existing)
            {
                item.IsActive = false;
            }
        }

        ResetForm();
        await LoadData();
    }

    private async Task DeleteFaculty(int id)
    {
        await FacultyRepo.SoftDeleteAsync(id);
        await ShowToast("Faculty Deactivated", "danger");
        await LoadData();
    }

    private async Task ActivateFaculty(int id)
    {
        await FacultyRepo.ActivateAsync(id);
        await ShowToast("Faculty Activated", "success");
        await LoadData();
    }

    private void EditFaculty(Faculty f)
    {
        if (!f.IsActive) return;

        model = new Faculty
            {
                FacultyId = f.FacultyId,
                FacultyName = f.FacultyName,
                Email = f.Email,
                Phone = f.Phone,
                FacultyCode = f.FacultyCode,
                DepartmentId = f.DepartmentId,
                MaxLecturesPerDay = f.MaxLecturesPerDay,
                IsExternal = f.IsExternal
            };

        isEditMode = true;
    }

    private void CancelEdit() => ResetForm();

    private async Task LoadData()
    {
        facultyList = await FacultyRepo.GetAllAsync();
    }

    private void ResetForm()
    {
        model = new Faculty();
        externalDepartmentId = 0;
        isEditMode = false;

        InitializeStickyDepartment();
    }

    private string GetTTDepartmentName()
    {
        // Helper to display the name in the disabled textbox
        var dept = departments.FirstOrDefault(d => d.DepartmentId == model.DepartmentId);
        return dept?.DepartmentName ?? "TT Department";
    }
