@page "/tt/academic/faculty"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

@using ScheduleX.Core.Entities
@using ScheduleX.Core.Interfaces.TTCoordinator
@inject IFacultyRepository FacultyRepo

@inject ScheduleX.Web.Services.AuthState Auth // Inject your auth service


<div class="faculty-page">
    <h3>Faculty Management</h3>

    <!-- ================= FORM ================= -->
    <div class="tt-card">

        <h4>Add Faculty</h4>

        <div class="form-grid-2">

            <div>
                <label>Name</label>
                <input class="tt-input" @bind="model.FacultyName" />
            </div>

            <div>
                <label>Email</label>
                <input class="tt-input" @bind="model.Email" />
            </div>

            <div>
                <label>Phone</label>
            @*     <input class="tt-input" @bind="model.Phone" /> *@
           
            <input class="tt-input"
                   @bind="model.Phone"
                   maxlength="10"
                   minlength="10"
                   pattern="[0-9]{10}"
                   inputmode="numeric"
                   oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0,10)" />
            </div>

            <div>
                <label>Faculty Code</label>
                <input class="tt-input" @bind="model.FacultyCode" />
            </div>

            <div>
                <label>Max Lectures</label>
                <input class="tt-input" type="number"
                       @bind-value="model.MaxLecturesPerDay"
                       @bind-value:event="oninput" />
            </div>

            <div>
                <label>Department</label>
                @if (!model.IsExternal)
                {
                        <input class="tt-input" value="@GetTTDepartmentName()" disabled />
                    
                }
            </div>

        </div>

        <br />

        <label>
            <input type="checkbox" @bind="model.IsExternal" />
            External Faculty
        </label>

        @if (model.IsExternal)
        {
            @* <select class="tt-input" @bind="externalDepartmentId"> *@
            @*     <option value="0">-- Select External Dept --</option> *@
            @*     @foreach (var d in departments.Where(d => d.DepartmentId != model.DepartmentId)) *@
            @*     { *@
            @*         <option value="@d.DepartmentId">@d.DepartmentName</option> *@
            @*     } *@
            @* </select> *@
            <div style="margin-top: 10px;">
                <label>Origin Department (External Source)</label>
                <select class="tt-input" @bind="externalDepartmentId">
                    <option value="0">-- Select External Dept --</option>
                    @* 🔥 FILTER: Hide the TT Coordinator's own department ID *@
                    @foreach (var d in departments.Where(d => d.DepartmentId != Auth.DepartmentId))
                    {
                        <option value="@d.DepartmentId">@d.DepartmentName</option>
                    }
                </select>
            </div>
        }

        <br />

        @if (isEditMode)
        {
            <button class="btn-success" @onclick="UpdateFaculty">Update</button>
            <button class="btn-danger" @onclick="CancelEdit">Cancel</button>
        }
        else
        {
            <button class="btn-save" @onclick="SaveFaculty">Save</button>
        }

    </div>

    <hr />

    <!-- ================= TABLE ================= -->
    <div class="tt-table">

        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Dept</th>
                    <th>Max Lec</th>
                    <th>External Dept</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var f in facultyList)
                {
                    <tr>
                        <td>@f.FacultyName</td>
                        <td>@f.FacultyCode</td>
                        <td>@f.Email</td>
                        <td>@f.Phone</td>
                        <td>@f.Department?.DepartmentName</td>
                        <td>@f.MaxLecturesPerDay</td>

                        <td>
                            @if (f.ExternalPermissions != null && f.ExternalPermissions.Any())
                            {
                                @string.Join(", ", f.ExternalPermissions.Select(x => x.Department.DepartmentName))
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>

                        <td>
                            <span class="status-badge @(f.IsActive ? "active" : "inactive")">
                                @(f.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>

                        <td>
                            <button class="btn-edit @(f.IsActive ? "" : "btn-edit-disabled")"
                                    disabled="@(!f.IsActive)"
                                    @onclick="() => EditFaculty(f)">
                                Edit
                            </button>

                            @if (f.IsActive)
                            {
                                <button class="btn-danger"
                                        @onclick="() => DeleteFaculty(f.FacultyId)">
                                    Deactivate
                                </button>
                            }
                            else
                            {
                                <button class="btn-success"
                                        @onclick="() => ActivateFaculty(f.FacultyId)">
                                    Activate
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

<!-- 🔥 TOAST (SAME AS SUBJECT PAGE) -->
@if (showToast)
{
    <div class="toast-container">
        <div class="toast-message @toastType">
            <span>@toastMessage</span>
            <div class="toast-progress"></div>
        </div>
    </div>
}

