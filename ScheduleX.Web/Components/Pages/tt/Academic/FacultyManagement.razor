@page "/tt/academic/faculty"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

@using ScheduleX.Core.Entities
@using ScheduleX.Core.Interfaces.TTCoordinator
@inject IFacultyRepository FacultyRepo

<link href="css/faculty.css" rel="stylesheet" />

<h3 class="page-title">Faculty Management</h3>

<!-- ================= FORM ================= -->
<div class="tt-card">

    <h4>@(isEditMode ? "Edit Faculty" : "Add Faculty")</h4>

    <div class="tt-form-grid">

        <div class="form-group">
            <label>Faculty Name</label>
            <input class="tt-input" @bind="model.FacultyName" />
        </div>

        <div class="form-group">
            <label>Faculty Code</label>
            <input class="tt-input" @bind="model.FacultyCode" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input class="tt-input" @bind="model.Email" />
        </div>

        <div class="form-group">
            <label>Phone</label>
            <input class="tt-input" @bind="model.Phone" />
        </div>

        <div class="form-group">
            <label>Department</label>
            <select class="tt-input" @bind="model.DepartmentId">
                <option value="0">-- Select Department --</option>
                @foreach (var d in departments)
                {
                    <option value="@d.DepartmentId">@d.DepartmentName</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label>Max Lectures</label>
            <input type="number" class="tt-input" @bind="model.MaxLecturesPerDay" />
        </div>

    </div>

    <div class="btn-group">
        <button class="btn-save" @onclick="SaveFaculty">
            @(isEditMode ? "Update" : "Save")
        </button>

        @if (isEditMode)
        {
            <button class="btn-cancel" @onclick="CancelEdit">Cancel</button>
        }
    </div>

</div>

<!-- ================= TABLE ================= -->
<div class="tt-table">
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Code</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Department</th>
                <th>Max</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var f in facultyList)
            {
                <tr class="@(f.IsActive ? "" : "inactive-row")">

                    <td>@f.FacultyName</td>
                    <td>@f.FacultyCode</td>
                    <td>@f.Email</td>
                    <td>@f.Phone</td>
                    <td>@f.Department?.DepartmentName</td>
                    <td>@f.MaxLecturesPerDay</td>

                    <td>
                        <span class="status-badge @(f.IsActive ? "active" : "inactive")">
                            @(f.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>

                    <td>
                        <div class="action-buttons">

                            <!-- EDIT -->
                            <button class="btn-edit"
                                    disabled="@(!f.IsActive)"
                                    @onclick="() => EditFaculty(f)">
                                Edit
                            </button>

                            <!-- ACTIVE / INACTIVE -->
                            @if (f.IsActive)
                            {
                                <button class="btn-danger"
                                        @onclick="() => Deactivate(f.FacultyId)">
                                    Deactivate
                                </button>
                            }
                            else
                            {
                                <button class="btn-success"
                                        @onclick="() => Activate(f.FacultyId)">
                                    Activate
                                </button>
                            }

                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>
</div>

@code {

    private Faculty model = new();
    private List<Faculty> facultyList = new();
    private List<Department> departments = new();
    private bool isEditMode = false;

    protected override async Task OnInitializedAsync()
    {
        departments = await FacultyRepo.GetDepartmentsAsync();
        facultyList = await FacultyRepo.GetAllAsync();
    }

    private async Task SaveFaculty()
    {
        if (model.DepartmentId == 0)
            return;

        if (isEditMode)
            await FacultyRepo.UpdateAsync(model);
        else
            await FacultyRepo.AddAsync(model);

        model = new Faculty();
        isEditMode = false;

        facultyList = await FacultyRepo.GetAllAsync();
    }

    // 🔥 FIXED EDIT (inactive block)
    private void EditFaculty(Faculty f)
    {
        if (!f.IsActive)
            return;

        model = new Faculty
            {
                FacultyId = f.FacultyId,
                FacultyName = f.FacultyName,
                FacultyCode = f.FacultyCode,
                Email = f.Email,
                Phone = f.Phone,
                DepartmentId = f.DepartmentId,
                MaxLecturesPerDay = f.MaxLecturesPerDay
            };

        isEditMode = true;
    }

    private async Task Deactivate(int id)
    {
        await FacultyRepo.SoftDeleteAsync(id);
        facultyList = await FacultyRepo.GetAllAsync();
    }

    private async Task Activate(int id)
    {
        await FacultyRepo.ActivateAsync(id);
        facultyList = await FacultyRepo.GetAllAsync();
    }

    private void CancelEdit()
    {
        model = new Faculty();
        isEditMode = false;
    }
}