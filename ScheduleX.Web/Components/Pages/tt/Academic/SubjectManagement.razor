    private async Task ProcessCsv()
    {
        if (selectedFile == null) return;

        isUploading = true;
        progress = 0;
        StateHasChanged();

        var dtoList = new List<SubjectCsvDto>();
        var entityList = new List<Subject>();

        using var stream = selectedFile.OpenReadStream();
        using var reader = new StreamReader(stream);

        string? line;
        bool isFirstRow = true;
        int count = 0;

        while ((line = await reader.ReadLineAsync()) != null)
        {
            if (isFirstRow)
            {
                isFirstRow = false;
                continue;
            }

            if (string.IsNullOrWhiteSpace(line))
                continue;

            var data = line.Split(',');

            if (data.Length < 5)
                continue;

            try
            {
                dtoList.Add(new SubjectCsvDto
                    {
                        SubjectName = data[0]?.Trim(),
                        SubjectCode = data[1]?.Trim(),
                        Credits = int.Parse(data[2]),
                        Category = data[3]?.Trim(),
                        CourseName = data[4]?.Trim()
                    });
            }
            catch { }

            count++;
            progress = Math.Min(50, count);

            await Task.Delay(1);
            StateHasChanged();
        }

        // 🔥 Convert DTO → ENTITY
        var courses = await Repo.GetCoursesAsync();

        foreach (var d in dtoList)
        {
            var course = courses.FirstOrDefault(c =>
                c.CourseName.Trim().Equals(
                    d.CourseName?.Trim(),
                    StringComparison.OrdinalIgnoreCase));

            if (course == null)
            {
                await ShowToast($"Invalid Course: {d.CourseName}", "danger");
                continue;
            }

            SubjectCategoryEnum category;

            if (int.TryParse(d.Category, out var cat))
            {
                category = (SubjectCategoryEnum)cat;
            }
            else
            {
                category = d.Category?.Trim().ToLower() switch
                {
                    "theory" => SubjectCategoryEnum.Theory,
                    "practical" => SubjectCategoryEnum.Practical,
                    "both" => SubjectCategoryEnum.Both,
                    _ => SubjectCategoryEnum.Theory
                };
            }

            entityList.Add(new Subject
                {
                    SubjectName = d.SubjectName,
                    SubjectCode = d.SubjectCode,
                    Credits = d.Credits,
                    SubjectCategory = category,
                    CourseId = course.CourseId
                });
        }

        if (!entityList.Any())
        {
            await ShowToast("No valid data found", "danger");
            return;
        }

        progress = 80;
        StateHasChanged();

        var result = await Repo.BulkInsertAsync(entityList);

        progress = 100;
        StateHasChanged();

        await ShowToast(result.Item2, result.Item1 ? "success" : "danger");

        isUploading = false;
        isFileSelected = false;

        await LoadData();
    }

    private async Task DownloadTemplate()
    {
        var csv = "SubjectName,SubjectCode,Credits,Category,CourseName\n";
        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);

        await JS.InvokeVoidAsync("downloadFile", "SubjectTemplate.csv", bytes);
    }

    private async Task ShowToast(string message, string type)
    {
        await JS.InvokeVoidAsync("showToast", message, type);
    }
