@page "/tt/academic/subject"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout
@inject ScheduleX.Web.Services.AuthState Auth
@using SubjectEntity = ScheduleX.Core.Entities.Subject
@using ScheduleX.Core.Entities
@using ScheduleX.Web.DTOs
@inject ISubjectRepository Repo
@inject IJSRuntime JS

<link href="/css/subject.css?v=2.0" rel="stylesheet" />
<div class="subject-page">
<h3 class="mb-4">Subject Management</h3>

<input class="tt-input w-100 mb-3"
       placeholder="Search subject..."
       @bind="searchText" />

<div class="mb-3">
        <div class="btn-section">
    <button class="btn btn-success me-2" @onclick="ShowManualForm">
        Add Subject
    </button>

    <button class="btn btn-warning" @onclick="ShowCsvForm">
        Upload CSV
    </button>
    </div>
</div>

@if (isUploading)
{
    <div class="progress-container mb-3">
        <div class="progress-bar" style="width:@progress%"></div>
    </div>
}

<!-- ================= FORM ================= -->
@if (showManualForm)
{
    <div class="tt-card p-4 mb-4">
        <h5>@(isEditMode ? "Edit Subject" : "Add Subject")</h5>

        <EditForm Model="model" OnValidSubmit="SaveSubject">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label>Name</label>
                    <InputText class="tt-input w-100"
                               @bind-Value="model.SubjectName" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Code</label>
                    <InputText class="tt-input w-100"
                               @bind-Value="model.SubjectCode" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Course</label>
                        @if (!courses.Any())
                        {
                            <p class="text-warning">No courses assigned to you</p>
                        }
                    <select class="tt-select w-100"
                            @bind="model.CourseId">
                        <option value="0">Select Course</option>
                        @foreach (var c in courses)
                        {
                            <option value="@c.CourseId">@c.CourseName</option>
                        }
                    </select>
                </div>
                    <div class="col-md-6 mb-3">
                        <label>Category</label>
                        <select class="tt-select w-100"
                                @onchange="OnCategoryChanged">
                            <option value="1">Theory</option>
                            <option value="2">Practical</option>
                            <option value="3">Both</option>
                        </select>
                    </div>
                    @if (model.SubjectCategory == SubjectCategoryEnum.Theory || model.SubjectCategory == SubjectCategoryEnum.Both)
                    {
                        <div class="col-md-6 mb-3">
                            <label>Theory Credits</label>
                            <InputNumber class="tt-input w-100"
                                         @bind-Value="model.TheoryCredits" />
                        </div>
                    }

                    @if (model.SubjectCategory == SubjectCategoryEnum.Practical || model.SubjectCategory == SubjectCategoryEnum.Both)
                    {
                        <div class="col-md-6 mb-3">
                            <label>Practical Credits</label>
                            <InputNumber class="tt-input w-100"
                                         @bind-Value="model.PracticalCredits" />
                        </div>
                    }
               

                <div class="col-md-6 mb-3">
                    <label>
                        <InputCheckbox @bind-Value="model.IsElective" />
                        Elective
                    </label>
                </div>

            </div>
            <div class="btn-section">
            <button type="submit" class="btn btn-success me-2">
                @(isEditMode ? "Update" : "Save")
            </button>

            <button type="button" class="btn btn-secondary" @onclick="CloseForm">
                Close
            </button>
            </div>
        </EditForm>
    </div>
}

<!-- ================= CSV ================= -->
@if (showCsvForm)
{
    <div class="tt-card p-4 mb-4">

        <h5>Upload CSV</h5>

        <button class="btn btn-info mb-2" @onclick="DownloadTemplate">
            Download Template
        </button>

        <InputFile OnChange="OnFileSelected" />

        <br />
            <div class="btn-section">
        <button class="btn btn-success mt-2"
                @onclick="ProcessCsv"
                disabled="@(!isFileSelected)">
            Insert Data
        </button>

        <button class="btn btn-secondary mt-2 ms-2"
                @onclick="CloseForm">
            Close
        </button>
        </div>
    </div>
}

<!-- ================= TABLE ================= -->
<div class="tt-card p-3">
    <table class="table table-dark table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Code</th>
                <th>Course</th>
                <th>Credits</th>
                <th>Status</th>
                <th width="160">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var s in filteredSubjects)
            {
                <tr class="@(s.IsActive ? "" : "opacity-50")">
                    <td>@s.SubjectName</td>
                    <td>@s.SubjectCode</td>
                    <td>@s.Course?.CourseName</td>
                    <td>
                            T: @s.TheoryCredits | P: @s.PracticalCredits
                    </td>
                    <td>
                        <span class="status-badge @(s.IsActive ? "active" : "inactive")">
                            @(s.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>

                        <td>
                            <div class="action-group">

                                <button class="btn btn-sm btn-info"
                                        disabled="@(!s.IsActive)"
                                        @onclick="() => EditSubject(s)">
                                    Edit
                                </button>

                                @if (s.IsActive)
                                {
                                    <button class="btn btn-sm btn-danger"
                                            @onclick="() => Delete(s.SubjectId)">
                                        Deactivate
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-success"
                                            @onclick="() => Activate(s.SubjectId)">
                                        Activate
                                    </button>
                                }

                            </div>
                        </td>
                </tr>
            }
        </tbody>
    </table>
</div>
</div>
@code {

    private List<SubjectEntity> subjects = new();
    private List<Course> courses = new();

    private SubjectEntity model = new()
        {
            SubjectCategory = SubjectCategoryEnum.Theory
        };

    private IBrowserFile? selectedFile;
    private bool isFileSelected = false;

    private bool showManualForm = false;
    private bool showCsvForm = false;
    private bool isEditMode = false;

    private string searchText = "";

    private bool isUploading = false;
    private int progress = 0;

    private int userId;

    private IEnumerable<SubjectEntity> filteredSubjects =>
        subjects.Where(s =>
            string.IsNullOrEmpty(searchText) ||
            s.SubjectName.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
            return;

        userId = Auth.UserId!.Value; // 🔥 CORRECT WAY
        await LoadData();
        courses = await Repo.GetCoursesForCoordinatorAsync(userId);
    }

    private async Task LoadData()
    {
        subjects = await Repo.GetAllAsync(userId);
    }

    private void ShowManualForm()
    {
        model = new SubjectEntity
            {
                SubjectCategory = SubjectCategoryEnum.Theory
            };

        showManualForm = true;
        showCsvForm = false;
        isEditMode = false;
    }

    private void ShowCsvForm()
    {
        showCsvForm = true;
        showManualForm = false;
    }

    private void CloseForm()
    {
        showManualForm = false;
        showCsvForm = false;
        isFileSelected = false;
    }

    private async Task SaveSubject()
    {
        if (string.IsNullOrWhiteSpace(model.SubjectCode))
        {
            await ShowToast("Subject Code required", "danger");
            return;
        }

        if (!courses.Any(c => c.CourseId == model.CourseId))
        {
            await ShowToast("Invalid Course Selection", "danger");
            return;
        }

        var result = isEditMode
            ? await Repo.UpdateAsync(model)
            : await Repo.AddAsync(model);

        await ShowToast(result.Item2, result.Item1 ? "success" : "danger");

        if (result.Item1)
        {
            await LoadData();
            CloseForm();
        }
    }

    private void EditSubject(SubjectEntity s)
    {
        model = new SubjectEntity
            {
                SubjectId = s.SubjectId,
                SubjectName = s.SubjectName,
                SubjectCode = s.SubjectCode,
                CourseId = s.CourseId,
                TheoryCredits = s.TheoryCredits,
                PracticalCredits = s.PracticalCredits,
                SubjectCategory = s.SubjectCategory,
                IsElective = s.IsElective
            };

        isEditMode = true;
        showManualForm = true;
    }

    private async Task Delete(int id)
    {
        await Repo.SoftDeleteAsync(id);
        await LoadData();
        await ShowToast("Deactivated", "warning");
    }

    private async Task Activate(int id)
    {
        await Repo.ActivateAsync(id);
        await LoadData();
        await ShowToast("Activated", "success");
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        isFileSelected = true;
    }
    private void OnCategoryChanged(ChangeEventArgs e)
    {
        model.SubjectCategory = (SubjectCategoryEnum)Convert.ToInt32(e.Value);

        if (model.SubjectCategory == SubjectCategoryEnum.Theory)
        {
            model.PracticalCredits = 0;
        }
        else if (model.SubjectCategory == SubjectCategoryEnum.Practical)
        {
            model.TheoryCredits = 0;
        }
    }
    private async Task ProcessCsv()
    {
        if (selectedFile == null) return;

        isUploading = true;
        progress = 0;

        var entityList = new List<Subject>();

        using var stream = selectedFile.OpenReadStream();
        using var reader = new StreamReader(stream);

        string? line;
        bool isFirstRow = true;

        while ((line = await reader.ReadLineAsync()) != null)
        {
            if (isFirstRow)
            {
                isFirstRow = false;
                continue;
            }

            if (string.IsNullOrWhiteSpace(line))
                continue;

            var data = line.Split(',');

            if (data.Length < 6)
                continue;

            int.TryParse(data[2], out var theory);
            int.TryParse(data[3], out var practical);

            if (!Enum.TryParse<SubjectCategoryEnum>(data[4], true, out var category))
            {
                await ShowToast($"Invalid Category: {data[4]}", "danger");
                continue;
            }

           

            var course = courses.FirstOrDefault(c =>
     c.CourseName.Equals(data[5]?.Trim(), StringComparison.OrdinalIgnoreCase));
            if (course == null)
            {
                await ShowToast($"Invalid Course: {data[5]}", "danger");
                continue;
            }

            entityList.Add(new Subject
                {
                    SubjectName = data[0]?.Trim(),
                    SubjectCode = data[1]?.Trim(),
                    TheoryCredits = theory,
                    PracticalCredits = practical,
                    SubjectCategory = category,
                    CourseId = course.CourseId
                });
        }

        if (!entityList.Any())
        {
            await ShowToast("No valid data found", "danger");
            return;
        }

        var result = await Repo.BulkInsertAsync(entityList, userId);

        await ShowToast(result.Item2, result.Item1 ? "success" : "danger");

        isUploading = false;
        isFileSelected = false;

        await LoadData();
    }

    private async Task DownloadTemplate()
    {
        var csv = "SubjectName,SubjectCode,TheoryCredits,PracticalCredits,Category,CourseName\n";

        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);

        await JS.InvokeVoidAsync("downloadFile", "SubjectTemplate.csv", bytes);
    }

    private async Task ShowToast(string message, string type)
    {
        await JS.InvokeVoidAsync("showToast", message, type);
    }
}