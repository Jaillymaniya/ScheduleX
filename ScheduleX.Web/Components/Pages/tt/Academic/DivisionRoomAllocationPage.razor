<div class="tt-card p-4 mt-4">

    <table class="table tt-table">
        <thead>
            <tr>
                <th>Semester</th>
                <th>Division</th>
                <th>Room</th>
                <th>Fixed</th>
                <th style="width:180px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in list)
            {
                <tr>
                    <td>@item.Semester?.SemesterNo</td>
                    <td>@item.Division?.DivisionName</td>
                    <td>@item.Room?.RoomName</td>

                    <td>
                        <span class="badge @(item.IsFixed ? "badge-success" : "badge-gray")">
                            @(item.IsFixed ? "Yes" : "No")
                        </span>
                    </td>

                    <td>
                        <div class="action-buttons">

                            <button class="btn-edit"
                                    @onclick="() => Edit(item)">
                                Edit
                            </button>

                            <button class="btn-delete"
                                    @onclick="() => Delete(item.AllocationId)">
                                Delete
                            </button>

                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

@code {

    DivisionRoomAllocation model = new();
    List<DivisionRoomAllocation> list = new();

    List<Semester> semesters = new();
    List<Division> divisions = new();
    List<Room> rooms = new();

    string? message;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        list = await Repo.GetAllAsync();
        semesters = await SemesterRepo.GetAllAsync();
        rooms = await RoomRepo.GetAllRoomsAsync();
        divisions = await DivisionService.GetAllDivisionsAsync();
    }

    async Task Save()
    {
        message = null;

        if (model.SemesterId == 0)
        {
            message = "Please select semester";
            return;
        }

        if (model.DivisionId == 0)
        {
            message = "Please select division";
            return;
        }

        if (model.RoomId == 0)
        {
            message = "Please select room";
            return;
        }

        try
        {
            if (model.AllocationId == 0)
                await Repo.AddAsync(model);
            else
                await Repo.UpdateAsync(model);

            await LoadData();
            Clear();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    void Edit(DivisionRoomAllocation item)
    {
        model = new DivisionRoomAllocation
            {
                AllocationId = item.AllocationId,
                SemesterId = item.SemesterId,
                DivisionId = item.DivisionId,
                RoomId = item.RoomId,
                IsFixed = item.IsFixed
            };
    }

    async Task Delete(int id)
    {
        await Repo.DeleteAsync(id);
        await LoadData();
    }

    void Clear()
    {
        model = new DivisionRoomAllocation();
        message = null;
    }
}