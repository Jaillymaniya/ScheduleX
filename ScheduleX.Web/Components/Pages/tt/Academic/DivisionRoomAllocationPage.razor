@page "/tt/academic/division-room-allocation"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

@using ScheduleX.Core.Entities
@using ScheduleX.Core.Interfaces.TTCoordinator

@inject IDivisionRoomAllocationRepository Repo
@inject ISemesterRepository SemesterRepo
@inject IRoomRepository RoomRepo
@inject IDivisionService DivisionService

<h3>Division Room Allocation</h3>

<!-- ================= FORM ================= -->
<div class="tt-card p-4 mb-4">

    <h5 class="mb-4">Allocate Room</h5>

    <div class="row g-4">

        <div class="col-md-6">
            <label>Semester</label>
            <select class="tt-select w-100" @bind="model.SemesterId">
                <option value="0">-- Select Semester --</option>
                @foreach (var s in semesters)
                {
                    <option value="@s.SemesterId">@s.SemesterNo</option>
                }
            </select>
        </div>

        <div class="col-md-6">
            <label>Division</label>
            <select class="tt-select w-100" @bind="model.DivisionId">
                <option value="0">-- Select Division --</option>
                @foreach (var d in divisions)
                {
                    <option value="@d.DivisionId">@d.DivisionName</option>
                }
            </select>
        </div>

        <div class="col-md-6">
            <label>Room</label>
            <select class="tt-select w-100" @bind="model.RoomId">
                <option value="0">-- Select Room --</option>
                @foreach (var r in rooms)
                {
                    <option value="@r.RoomId">@r.RoomName</option>
                }
            </select>
        </div>

        <div class="col-md-6 d-flex align-items-end">
            <div>
                <input type="checkbox" @bind="model.IsFixed" />
                <label style="display:inline; margin-left:8px;">Fixed</label>
            </div>
        </div>

    </div>

    <div class="mt-4">
        <button class="btn btn-success px-4"
                @onclick="Save">
            @(model.AllocationId == 0 ? "Save Allocation" : "Update Allocation")
        </button>

        <button class="btn btn-secondary ms-2"
                @onclick="Clear">
            Clear
        </button>
    </div>

</div>

<hr />

<!-- ================= TABLE ================= -->
<div class="tt-card p-4 mt-4">

    <table class="table tt-table">
        <thead>
            <tr>
                <th>Semester</th>
                <th>Division</th>
                <th>Room</th>
                <th>Fixed</th>
                <th style="width:180px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in list)
            {
                <tr>
                    <td>@item.Semester?.SemesterNo</td>
                    <td>@item.Division?.DivisionName</td>
                    <td>@item.Room?.RoomName</td>

                    <td>
                        <span class="badge @(item.IsFixed ? "badge-success" : "badge-gray")">
                            @(item.IsFixed ? "Yes" : "No")
                        </span>
                    </td>

                    <td>
                        <div class="action-buttons">

                            <button class="btn-edit"
                                    @onclick="() => Edit(item)">
                                Edit
                            </button>

                            <button class="btn-delete"
                                    @onclick="() => Delete(item.AllocationId)">
                                Delete
                            </button>

                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

<!-- 🔥 TOAST -->
@if (showToast)
{
    <div class="toast-container">
        <div class="toast-message @toastType">
            <span>@toastMessage</span>
            <div class="toast-progress"></div>
        </div>
    </div>
}

@code {

    DivisionRoomAllocation model = new();
    List<DivisionRoomAllocation> list = new();

    List<Semester> semesters = new();
    List<Division> divisions = new();
    List<Room> rooms = new();

    // 🔥 TOAST
    bool showToast = false;
    string toastMessage = "";
    string toastType = "success";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        list = await Repo.GetAllAsync();
        semesters = await SemesterRepo.GetAllAsync();
        rooms = await RoomRepo.GetAllRoomsAsync();
        divisions = await DivisionService.GetAllDivisionsAsync();
    }

    async Task ShowToast(string message, string type = "success")
    {
        toastMessage = message;
        toastType = type;
        showToast = true;

        StateHasChanged();

        await Task.Delay(3000);

        showToast = false;
        StateHasChanged();
    }

    async Task Save()
    {
        // 🔴 VALIDATION
        if (model.SemesterId == 0)
        {
            await ShowToast("Please select Semester", "danger");
            return;
        }

        if (model.DivisionId == 0)
        {
            await ShowToast("Please select Division", "danger");
            return;
        }

        if (model.RoomId == 0)
        {
            await ShowToast("Please select Room", "danger");
            return;
        }

        try
        {
            if (model.AllocationId == 0)
            {
                await Repo.AddAsync(model);
                await ShowToast("Allocation Added Successfully", "success");
            }
            else
            {
                await Repo.UpdateAsync(model);
                await ShowToast("Allocation Updated Successfully", "info");
            }

            await LoadData();
            Clear();
        }
        catch (Exception ex)
        {
            await ShowToast(ex.Message, "danger");
        }
    }

    void Edit(DivisionRoomAllocation item)
    {
        model = new DivisionRoomAllocation
            {
                AllocationId = item.AllocationId,
                SemesterId = item.SemesterId,
                DivisionId = item.DivisionId,
                RoomId = item.RoomId,
                IsFixed = item.IsFixed
            };
    }

    async Task Delete(int id)
    {
        await Repo.DeleteAsync(id);
        await ShowToast("Allocation Deleted", "danger");

        await LoadData();
    }

    void Clear()
    {
        model = new DivisionRoomAllocation();
    }
}