@page "/tt/academic/division-room-allocation"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

@using ScheduleX.Core.Entities
@using ScheduleX.Core.Interfaces.TTCoordinator

@inject IDivisionRoomAllocationRepository Repo
@inject ISemesterRepository SemesterRepo
@inject IRoomRepository RoomRepo
@inject IDivisionService DivisionService
<link href="css/division-room-allocation.css" rel="stylesheet" />

<h3>Division Room Allocation</h3>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert">@message</div>
}

<!-- ================= FORM ================= -->
<div class="tt-card p-4 mb-4">

    <h5 class="mb-4">Allocate Room</h5>

    <div class="row g-4">

        <!-- Semester -->
        <div class="col-md-6">
            <label>Semester</label>
            <select class="tt-select w-100" @bind="model.SemesterId">
                <option value="0">-- Select Semester --</option>
                @foreach (var s in semesters)
                {
                    <option value="@s.SemesterId">@s.SemesterNo</option>
                }
            </select>
        </div>

        <!-- Division -->
        <div class="col-md-6">
            <label>Division</label>
            <select class="tt-select w-100" @bind="model.DivisionId">
                <option value="0">-- Select Division --</option>
                @foreach (var d in divisions)
                {
                    <option value="@d.DivisionId">@d.DivisionName</option>
                }
            </select>
        </div>

        <!-- Room -->
        <div class="col-md-6">
            <label>Room</label>
            <select class="tt-select w-100" @bind="model.RoomId">
                <option value="0">-- Select Room --</option>
                @foreach (var r in rooms)
                {
                    <option value="@r.RoomId">@r.RoomName</option>
                }
            </select>
        </div>

        <!-- Fixed -->
        <div class="col-md-6 d-flex align-items-end">
            <div>
                <input type="checkbox" @bind="model.IsFixed" />
                <label style="display:inline; margin-left:8px;">Fixed</label>
            </div>
        </div>

    </div>

    <!-- BUTTON -->
    <div class="mt-4">
        <button class="btn btn-success px-4"
                @onclick="Save">
            @(model.AllocationId == 0 ? "Save Allocation" : "Update Allocation")
        </button>

        <button class="btn btn-secondary ms-2"
                @onclick="Clear">
            Clear
        </button>
    </div>

</div>

<hr />

