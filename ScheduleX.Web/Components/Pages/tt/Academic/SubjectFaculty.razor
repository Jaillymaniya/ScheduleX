@page "/tt/subject-faculty"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

@using System.IO
@using System.Text
@using ScheduleX.Core.Entities
@using ScheduleX.Web.DTOs

@using SubjectFacultyEntity = ScheduleX.Core.Entities.SubjectFaculty
@using SubjectSemesterEntity = ScheduleX.Core.Entities.SubjectSemester

@inject ISubjectFacultyRepository Repo
@inject IJSRuntime JS
@inject ScheduleX.Web.Services.AuthState Auth

<link href="css/subjectfaculty.css" rel="stylesheet" />

<h3 class="mb-3">Subject ↔ Faculty Mapping</h3>

<!-- BUTTONS -->
<div class="btn-section">
    <button class="btn btn-success me-2" @onclick="()=>ShowManual()">Add Manual</button>
    <button class="btn btn-warning" @onclick="()=>showCsv=true">Upload CSV</button>
</div>

<!-- ================= MANUAL ================= -->
@if (showManual)
{
    <div class="tt-card">

        <div class="subject-grid">

            <!-- COURSE -->
            <div class="form-field">
                <label>Course</label>
                <select class="tt-select" @bind="courseId" @bind:after="LoadSemesters">
                    <option value="0">Select</option>
                    @foreach (var c in courses)
                    {
                        <option value="@c.CourseId">@c.CourseName</option>
                    }
                </select>
            </div>

            <!-- SEM -->
            <div class="form-field">
                <label>Semester</label>
                <select class="tt-select" @bind="semesterId" @bind:after="LoadData">
                    <option value="0">Select</option>
                    @foreach (var s in semesters)
                    {
                        <option value="@s.SemesterId">Sem @s.SemesterNo</option>
                    }
                </select>
            </div>

            <!-- SUBJECT -->
            <div class="form-field">
                <label>Subject</label>
                <select class="tt-select @(model.SubjectSemesterId==0?"input-error":"")"
                        @bind="model.SubjectSemesterId">
                    <option value="0">Select</option>
                    @foreach (var s in subjectSemesters)
                    {
                        <option value="@s.SubjectSemesterId">@s.Subject.SubjectName</option>
                    }
                </select>
            </div>

            <!-- DIVISION -->
            <div class="form-field">
                <label>Division</label>
                <select class="tt-select @(model.DivisionId==0?"input-error":"")"
                        @bind="model.DivisionId">
                    <option value="0">Select</option>
                    @foreach (var d in divisions)
                    {
                        <option value="@d.DivisionId">@d.DivisionName</option>
                    }
                </select>
            </div>

            <!-- FACULTY -->
            <div class="form-field">
                <label>Faculty</label>
                <select class="tt-select @(model.FacultyId==0?"input-error":"")"
                        @bind="model.FacultyId">
                    <option value="0">Select</option>
                    @foreach (var f in faculties)
                    {
                        <option value="@f.FacultyId">@f.Email</option>
                    }
                </select>
            </div>

        </div>

        <button class="btn btn-success mt-3" @onclick="Save">
            @(isEditMode ? "Update" : "Save")
        </button>

        <button class="btn btn-secondary mt-3 ms-2" @onclick="CloseForm">
            Cancel
        </button>
    </div>
}

<!-- ================= CSV ================= -->
@if (showCsv)
{
    <div class="tt-card p-3">

        <!-- COURSE -->
        <select class="tt-select mb-2" @bind="courseId" @bind:after="LoadSemesters">
            <option value="0">Select Course</option>
            @foreach (var c in courses)
            {
                <option value="@c.CourseId">@c.CourseName</option>
            }
        </select>

        <!-- SEM -->
        <select class="tt-select mb-2" @bind="semesterId" @bind:after="LoadCsvData">
            <option value="0">Select Semester</option>
            @foreach (var s in semesters)
            {
                <option value="@s.SemesterId">Sem @s.SemesterNo</option>
            }
        </select>

        <!-- DIVISION -->
        <select class="tt-select mb-2" @bind="divisionId">
            <option value="0">Select Division</option>
            @foreach (var d in divisions)
            {
                <option value="@d.DivisionId">@d.DivisionName</option>
            }
        </select>

        <button class="btn btn-info mb-2" @onclick="GenerateCsv">
            Generate CSV Format
        </button>

        <InputFile OnChange="OnFileSelected" />

        <button class="btn btn-success mt-2" @onclick="ProcessCsv">
            Upload CSV
        </button>

        <button class="btn btn-secondary mt-2 ms-2" @onclick="()=>showCsv=false">
            Close
        </button>
    </div>
}
<!-- ================= TABLE ================= -->
<div class="tt-card">
    <table class="table table-dark">
        <thead>
            <tr>
                <th>Course</th>
                <th>Sem</th>
                <th>Division</th>
                <th>Subject</th>
                <th>Faculty</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in filteredList)
            {
                <tr class="@(item.IsActive ? "" : "opacity-50")">

                    <td>@item.SubjectSemester.Semester.Course.CourseName</td>
                    <td>@item.SubjectSemester.Semester.SemesterNo</td>
                    <td>@item.Division.DivisionName</td>
                    <td>@item.SubjectSemester.Subject.SubjectName</td>
                    <td>@item.Faculty.Email</td>

                    <td>
                        <div class="action-group">

                            <button class="btn btn-info btn-sm"
                                    disabled="@(!item.IsActive)"
                                    @onclick="()=>Edit(item)">
                                Edit
                            </button>

                            <button class="btn btn-sm @(item.IsActive ? "btn-danger":"btn-success")"
                                    @onclick="()=>Toggle(item.SubjectFacultyId)">
                                @(item.IsActive ? "Deactivate" : "Activate")
                            </button>

                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {

    List<Course> courses = new();
    List<Semester> semesters = new();
    List<Division> divisions = new();
    List<SubjectSemesterEntity> subjectSemesters = new();
    List<Faculty> faculties = new();
    List<SubjectFacultyEntity> list = new();

    SubjectFacultyEntity model = new();

    int courseId, semesterId;
    int divisionId;
    bool showManual, showCsv, isEditMode;

    IBrowserFile? file;

    IEnumerable<SubjectFacultyEntity> filteredList =>
        list.Where(x =>
            (courseId == 0 || x.SubjectSemester.Semester.CourseId == courseId) &&
            (semesterId == 0 || x.SubjectSemester.SemesterId == semesterId));

    protected override async Task OnInitializedAsync()
    {
        var userId = Auth.UserId!.Value;

        courses = await Repo.GetCoursesByCoordinator(userId);
        list = await Repo.GetAllAsync();
    }

    void ShowManual()
    {
        model = new SubjectFacultyEntity();
        showManual = true;
        isEditMode = false;
    }

    void CloseForm()
    {
        showManual = false;
    }

    async Task LoadSemesters()
    {
        semesters = await Repo.GetSemesters(courseId);
    }

    async Task LoadData()
    {
        subjectSemesters = await Repo.GetSubjectSemesters(semesterId);
        divisions = await Repo.GetDivisions(semesterId);
        faculties = await Repo.GetFaculties(courseId);
    }
    async Task LoadCsvData()
    {
        subjectSemesters = await Repo.GetSubjectSemesters(semesterId);
        divisions = await Repo.GetDivisions(semesterId);
    }
    async Task GenerateCsv()
    {
        if (courseId == 0 || semesterId == 0 || divisionId == 0)
        {
            await ShowToast("Select Course, Semester, Division", "danger");
            return;
        }

        var selectedCourse = courses.First(x => x.CourseId == courseId);
        var selectedSemester = semesters.First(x => x.SemesterId == semesterId);
        var selectedDivision = divisions.First(x => x.DivisionId == divisionId);

        var sb = new StringBuilder();
        sb.AppendLine("CourseName,SemesterNo,SubjectName,DivisionName,FacultyEmail");

        foreach (var s in subjectSemesters)
        {
            sb.AppendLine($"{selectedCourse.CourseName}," +
                          $"{selectedSemester.SemesterNo}," +
                          $"{s.Subject.SubjectName}," +
                          $"{selectedDivision.DivisionName},");
        }

        var bytes = Encoding.UTF8.GetBytes(sb.ToString());

        await JS.InvokeVoidAsync("downloadFile", "SubjectFacultyTemplate.csv", bytes);
    }
    void Edit(SubjectFacultyEntity item)
    {
        model = new SubjectFacultyEntity
            {
                SubjectFacultyId = item.SubjectFacultyId,
                SubjectSemesterId = item.SubjectSemesterId,
                DivisionId = item.DivisionId,
                FacultyId = item.FacultyId
            };

        showManual = true;
        isEditMode = true;
    }

    async Task Save()
    {
        if (model.SubjectSemesterId == 0 ||
            model.DivisionId == 0 ||
            model.FacultyId == 0)
        {
            await ShowToast("All fields required", "danger");
            return;
        }

        var result = isEditMode
            ? await Repo.UpdateAsync(model)
            : await Repo.AddAsync(model);

        await ShowToast(result.Item2, result.Item1 ? "success" : "danger");

        list = await Repo.GetAllAsync();
        showManual = false;
    }

    async Task Toggle(int id)
    {
        await Repo.ToggleAsync(id);
        list = await Repo.GetAllAsync();
    }

    void OnFileSelected(InputFileChangeEventArgs e) => file = e.File;

    async Task ProcessCsv()
    {
        if (file == null)
        {
            await ShowToast("Select CSV file", "danger");
            return;
        }

        if (courseId == 0 || semesterId == 0 || divisionId == 0)
        {
            await ShowToast("Select Course, Semester, Division first", "danger");
            return;
        }

        var userId = Auth.UserId!.Value;
        var finalList = new List<SubjectFacultyEntity>();

        using var reader = new StreamReader(file.OpenReadStream());

        int row = 1;
        bool first = true;

        while (!reader.EndOfStream)
        {
            var line = await reader.ReadLineAsync();

            if (first) { first = false; continue; }

            row++;

            if (string.IsNullOrWhiteSpace(line))
                continue;

            var data = line.Split(',');

            if (data.Length < 5)
            {
                await ShowToast($"Row {row}: Invalid column format", "danger");
                return;
            }

            var courseName = data[0]?.Trim();
            var semNoStr = data[1]?.Trim();
            var subjectName = data[2]?.Trim();
            var divisionName = data[3]?.Trim();
            var facultyEmail = data[4]?.Trim();

            // 🔥 VALIDATIONS

            if (string.IsNullOrWhiteSpace(courseName))
            {
                await ShowToast($"Row {row}: Course is required", "danger");
                return;
            }

            if (!byte.TryParse(semNoStr, out var semNo))
            {
                await ShowToast($"Row {row}: Invalid Semester", "danger");
                return;
            }

            if (string.IsNullOrWhiteSpace(subjectName))
            {
                await ShowToast($"Row {row}: Subject required", "danger");
                return;
            }

            if (string.IsNullOrWhiteSpace(divisionName))
            {
                await ShowToast($"Row {row}: Division required", "danger");
                return;
            }

            if (string.IsNullOrWhiteSpace(facultyEmail))
            {
                await ShowToast($"Row {row}: Faculty Email required", "danger");
                return;
            }

            // 🔥 MATCH VALID DATA

            var subject = subjectSemesters
                .FirstOrDefault(x => x.Subject.SubjectName == subjectName);

            if (subject == null)
            {
                await ShowToast($"Row {row}: Invalid Subject '{subjectName}'", "danger");
                return;
            }

            var division = divisions
                .FirstOrDefault(x => x.DivisionName == divisionName);

            if (division == null)
            {
                await ShowToast($"Row {row}: Invalid Division '{divisionName}'", "danger");
                return;
            }

            var faculty = await Repo.GetFacultyByEmail(facultyEmail);

            if (faculty == null)
            {
                await ShowToast($"Row {row}: Faculty not found '{facultyEmail}'", "danger");
                return;
            }

            finalList.Add(new SubjectFacultyEntity
                {
                    SubjectSemesterId = subject.SubjectSemesterId,
                    DivisionId = division.DivisionId,
                    FacultyId = faculty.FacultyId
                });
        }

        if (!finalList.Any())
        {
            await ShowToast("No valid data found", "danger");
            return;
        }

        var result = await Repo.BulkInsertAsync(finalList, userId);

        await ShowToast(result.Item2, result.Item1 ? "success" : "danger");

        list = await Repo.GetAllAsync();
    }

   
    async Task DownloadTemplate()
    {
        var csv = "CourseName,SemesterNo,SubjectName,DivisionName,FacultyEmail\n";
        var bytes = Encoding.UTF8.GetBytes(csv);

        await JS.InvokeVoidAsync("downloadFile", "template.csv", bytes);
    }

    async Task ShowToast(string msg, string type)
    {
        await JS.InvokeVoidAsync("showToast", msg, type);
    }
}