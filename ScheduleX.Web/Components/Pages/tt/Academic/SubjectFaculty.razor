@page "/tt/subject-faculty"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

@using System.IO
@using System.Text
@using ScheduleX.Core.Entities


@using SubjectFacultyEntity = ScheduleX.Core.Entities.SubjectFaculty
@using SubjectSemesterEntity = ScheduleX.Core.Entities.SubjectSemester

@inject ISubjectFacultyRepository Repo
@inject IJSRuntime JS
@inject ScheduleX.Web.Services.AuthState Auth

<link href="css/subjectfaculty.css" rel="stylesheet" />

<h3 class="mb-3">Subject ↔ Faculty Mapping</h3>

<!-- BUTTONS -->
<div class="btn-section">
    <button class="btn btn-success me-2" @onclick="()=>ShowManual()">Add Manual</button>
    <button class="btn btn-warning" @onclick="()=>showCsv=true">Upload CSV</button>
</div>

<!-- ================= MANUAL ================= -->
@if (showManual)
{
   <div class="tt-card">

    <div class="subject-grid">

        <!-- COURSE -->
        <div class="form-field">
                <label>Course (Assigned to You)</label>
            <select class="tt-select" @bind="courseId" @bind:after="LoadSemesters">
                <option value="0">Select Course</option>
                @foreach (var c in courses)
                {
                    <option value="@c.CourseId">@c.CourseName</option>
                }
            </select>
        </div>

        <!-- SEM -->
        <div class="form-field">
            <label>Select Semester</label>
            <select class="tt-select" @bind="semesterId" @bind:after="LoadData">
                <option value="0">Select Semester</option>
                @foreach (var s in semesters)
                {
                    <option value="@s.SemesterId">Sem @s.SemesterNo</option>
                }
            </select>
        </div>

        <!-- DIVISION -->
        <div class="form-field">
            <label>Select Division</label>
            <select class="tt-select" @bind="model.DivisionId">
                <option value="0">Select Division</option>
                @foreach (var d in divisions)
                {
                    <option value="@d.DivisionId">@d.DivisionName</option>
                }
            </select>
        </div>

        <!-- SUBJECT -->
        <div class="form-field">
                <label>Subject (Unassigned Only)</label>
            <select class="tt-select" @bind="model.SubjectSemesterId">
                <option value="0">Select Subject</option>
                @foreach (var s in subjectSemesters)
                {
                        <option value="@s.SubjectSemesterId"
                                disabled="@IsSubjectFullyAssigned(s.SubjectSemesterId)">
                            @s.Subject.SubjectName (@s.Subject.SubjectCategory)
                        </option>
                }
            </select>
        </div>

        <!-- EXTERNAL CHECK -->
        <div class="form-field">
            <label>
                    <input type="checkbox" @bind="isExternal" @bind:after="LoadDepartments" />
                Assign External Faculty
            </label>
        </div>

        @if (isExternal)
        {
            <div class="form-field">
                <label>Select Department</label>
                <select class="tt-select" @bind="externalDeptId" @bind:after="LoadExternalFaculty">
                    <option value="0">Select Department</option>
                    @foreach (var d in departments)
                    {
                        <option value="@d.DepartmentId">@d.DepartmentName</option>
                    }
                </select>
            </div>
        }

        @{
            var selectedSubject = subjectSemesters
                .FirstOrDefault(x => x.SubjectSemesterId == model.SubjectSemesterId);
        }

        @if (selectedSubject != null)
        {
            var cat = selectedSubject.Subject.SubjectCategory;

            <!-- THEORY -->
            @if (cat == SubjectCategoryEnum.Theory || cat == SubjectCategoryEnum.Both)
            {
                <div class="form-field">
                    <label>Theory Faculty</label>
                    <select class="tt-select" @bind="theoryFacultyId">
                        <option value="0">Select Faculty</option>
                        @foreach (var f in isExternal ? externalFaculties : faculties)
                        {
                            <option value="@f.FacultyId">@f.Email</option>
                        }
                    </select>
                </div>
            }

            <!-- PRACTICAL -->
            @if (cat == SubjectCategoryEnum.Practical || cat == SubjectCategoryEnum.Both)
            {
                <div class="form-field">
                    <label>Practical Faculty</label>
                    <select class="tt-select" @bind="practicalFacultyId">
                        <option value="0">Select Faculty</option>
                        @foreach (var f in isExternal ? externalFaculties : faculties)
                        {
                            <option value="@f.FacultyId">@f.Email</option>
                        }
                    </select>
                </div>
            }
        }

    </div>

    <div class="btn-section">
        <button class="btn btn-success" @onclick="SaveManual">Save</button>
        <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
    </div>
</div>
}

<!-- ================= CSV ================= -->
@if (showCsv)
{
    <div class="tt-card p-3">
        <label>Select Course</label>
        <!-- COURSE -->
        <select class="tt-select mb-2" @bind="courseId" @bind:after="LoadSemesters">
            <option value="0">Select Course</option>
            @foreach (var c in courses)
            {
                <option value="@c.CourseId">@c.CourseName</option>
            }
        </select>
        <label>Select Semester</label>
        <!-- SEM -->
        <select class="tt-select mb-2" @bind="semesterId" @bind:after="LoadCsvData">
            <option value="0">Select Semester</option>
            @foreach (var s in semesters)
            {
                <option value="@s.SemesterId">Sem @s.SemesterNo</option>
            }
        </select>
        <label>Select Division</label>
        <!-- DIVISION -->
        <select class="tt-select mb-2" @bind="divisionId">
            <option value="0">Select Division</option>
            @foreach (var d in divisions)
            {
                <option value="@d.DivisionId">@d.DivisionName</option>
            }
        </select>

        <button class="btn btn-info mb-2" @onclick="GenerateCsv">
            Generate CSV Format
        </button>

        <InputFile OnChange="OnFileSelected" />

        <button class="btn btn-success mt-2" @onclick="ProcessCsv">
            Upload CSV
        </button>

        <button class="btn btn-secondary mt-2 ms-2" @onclick="()=>showCsv=false">
            Close
        </button>
    </div>
}
<!-- ================= TABLE ================= -->
<div class="tt-card">
    <table class="table table-dark">
        <thead>
            <tr>
                <th>Course</th>
                <th>Sem</th>
                <th>Division</th>
                <th>Subject</th>
                <th>Type</th>
                <th>Faculty</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in filteredList)
            {
                <tr class="@(item.IsActive ? "" : "opacity-50")">

                    <td>@item.SubjectSemester.Semester.Course.CourseName</td>
                    <td>@item.SubjectSemester.Semester.SemesterNo</td>
                    <td>@item.Division.DivisionName</td>
                    <td>@item.SubjectSemester.Subject.SubjectName</td>
                    <td>@item.TeachingType</td>
                    <td>@item.Faculty.Email</td>

                    <td>
                        <div class="action-group">

                            <button class="btn btn-info btn-sm"
                                    disabled="@(!item.IsActive)"
                                    @onclick="()=>Edit(item)">
                                Edit
                            </button>

                            <button class="btn btn-sm @(item.IsActive ? "btn-danger":"btn-success")"
                                    @onclick="()=>Toggle(item.SubjectFacultyId)">
                                @(item.IsActive ? "Deactivate" : "Activate")
                            </button>

                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {

    List<Course> courses = new();
    List<Semester> semesters = new();
    List<Division> divisions = new();
    List<SubjectSemesterEntity> subjectSemesters = new();
    List<Faculty> faculties = new();
    List<SubjectFacultyEntity> list = new();

    SubjectFacultyEntity model = new();

    int courseId, semesterId;
    int divisionId;
    bool showManual, showCsv, isEditMode;
    bool isExternal = false;

    int externalDeptId;
    List<Department> departments = new();
    List<Faculty> externalFaculties = new();

    int theoryFacultyId;
    int practicalFacultyId;
    IBrowserFile? file;

    IEnumerable<SubjectFacultyEntity> filteredList =>
        list.Where(x =>
            (courseId == 0 || x.SubjectSemester.Semester.CourseId == courseId) &&
            (semesterId == 0 || x.SubjectSemester.SemesterId == semesterId));

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
            return;

        var userId = Auth.UserId ?? 0;

        courses = await Repo.GetCoursesByCoordinator(userId);

        if (!courses.Any())
        {
            await JS.InvokeVoidAsync("showToast", "No courses assigned to you", "warning");
        }

        list = await Repo.GetAllAsync();
    }

    void ShowManual()
    {
        model = new SubjectFacultyEntity();
        showManual = true;
        isEditMode = false;
    }

    void CloseForm()
    {
        showManual = false;
    }

    async Task LoadSemesters()
    {
        semesters = await Repo.GetSemesters(courseId);
    }
    bool IsSubjectFullyAssigned(int subjectSemesterId)
    {
        var assigned = list.Where(x =>
            x.SubjectSemesterId == subjectSemesterId &&
            x.DivisionId == model.DivisionId &&
            x.IsActive).ToList();

        var hasTheory = assigned.Any(x => x.TeachingType == SubjectCategoryEnum.Theory);
        var hasPractical = assigned.Any(x => x.TeachingType == SubjectCategoryEnum.Practical);

        return hasTheory && hasPractical;
    }
    async Task LoadData()
    {
        subjectSemesters = await Repo.GetSubjectSemesters(semesterId);
        divisions = await Repo.GetDivisions(semesterId);
        faculties = await Repo.GetFaculties(courseId);

        // ❗ APPLY FILTER ONLY WHEN DIVISION SELECTED
        if (model.DivisionId > 0)
        {
            subjectSemesters = subjectSemesters
                .Where(s => !list.Any(x =>
                    x.SubjectSemesterId == s.SubjectSemesterId &&
                    x.DivisionId == model.DivisionId))
                .ToList();
        }
    }
    async Task LoadDepartments()
    {
        departments = await Repo.GetDepartments();
    }

    async Task LoadExternalFaculty()
    {
        var allFaculties = await Repo.GetFaculties(courseId);

        externalFaculties = allFaculties
            .Where(f => f.IsExternal && f.IsActive)
            .ToList();
    }
    async Task LoadCsvData()
    {
        subjectSemesters = await Repo.GetSubjectSemesters(semesterId);
        divisions = await Repo.GetDivisions(semesterId);
    }
    async Task GenerateCsv()
    {
        if (courseId == 0 || semesterId == 0 || divisionId == 0)
        {
            await ShowToast("Please select Course, Semester and Division", "danger");
            return;
        }

        var selectedCourse = courses.First(x => x.CourseId == courseId);
        var selectedSemester = semesters.First(x => x.SemesterId == semesterId);
        var selectedDivision = divisions.First(x => x.DivisionId == divisionId);

        var sb = new StringBuilder();

        // 🔥 UPDATED HEADER
        sb.AppendLine("CourseName,SemesterNo,SubjectName,DivisionName,TheoryFacultyEmail,PracticalFacultyEmail");

        foreach (var s in subjectSemesters)
        {
            sb.AppendLine($"{selectedCourse.CourseName}," +
                          $"{selectedSemester.SemesterNo}," +
                          $"{s.Subject.SubjectName}," +
                          $"{selectedDivision.DivisionName},,");
        }

        var bytes = Encoding.UTF8.GetBytes(sb.ToString());

        await JS.InvokeVoidAsync("downloadFile", "SubjectFacultyTemplate.csv", bytes);
    }
    void Edit(SubjectFacultyEntity item)
    {
        showManual = true;
        isEditMode = true;

        model.SubjectSemesterId = item.SubjectSemesterId;
        model.DivisionId = item.DivisionId;

        courseId = item.SubjectSemester.Semester.CourseId;
        semesterId = item.SubjectSemester.SemesterId;

        _ = LoadSemesters();
        _ = LoadData();

        // 🔥 RESET
        theoryFacultyId = 0;
        practicalFacultyId = 0;

        // 🔥 LOAD BOTH TYPES
        var related = list.Where(x =>
            x.SubjectSemesterId == item.SubjectSemesterId &&
            x.DivisionId == item.DivisionId).ToList();

        foreach (var r in related)
        {
            if (r.TeachingType == SubjectCategoryEnum.Theory)
                theoryFacultyId = r.FacultyId;

            if (r.TeachingType == SubjectCategoryEnum.Practical)
                practicalFacultyId = r.FacultyId;
        }
    }

   
    async Task SaveManual()
    {
        if (model.DivisionId == 0)
        {
            await ShowToast("Select Division", "danger");
            return;
        }

        if (model.SubjectSemesterId == 0)
        {
            await ShowToast("Select Subject", "danger");
            return;
        }

        var subject = subjectSemesters
            .First(x => x.SubjectSemesterId == model.SubjectSemesterId);

        var category = subject.Subject.SubjectCategory;

        // ================= VALIDATION =================

        if (category == SubjectCategoryEnum.Theory && theoryFacultyId == 0)
        {
            await ShowToast("Select Theory Faculty", "danger");
            return;
        }

        if (category == SubjectCategoryEnum.Practical && practicalFacultyId == 0)
        {
            await ShowToast("Select Practical Faculty", "danger");
            return;
        }

        if (category == SubjectCategoryEnum.Both && theoryFacultyId == 0 && practicalFacultyId == 0)
        {
            await ShowToast("Select at least one faculty", "danger");
            return;
        }

        // ================= DUPLICATE CHECK (ONLY FOR ADD) =================
        if (!isEditMode)
        {
            var existsTheory = list.Any(x =>
                x.SubjectSemesterId == model.SubjectSemesterId &&
                x.DivisionId == model.DivisionId &&
                x.TeachingType == SubjectCategoryEnum.Theory &&
                x.IsActive);

            var existsPractical = list.Any(x =>
                x.SubjectSemesterId == model.SubjectSemesterId &&
                x.DivisionId == model.DivisionId &&
                x.TeachingType == SubjectCategoryEnum.Practical &&
                x.IsActive);

            if (existsTheory && (category == SubjectCategoryEnum.Theory || category == SubjectCategoryEnum.Both))
            {
                await ShowToast("Theory already assigned", "warning");
                return;
            }

            if (existsPractical && (category == SubjectCategoryEnum.Practical || category == SubjectCategoryEnum.Both))
            {
                await ShowToast("Practical already assigned", "warning");
                return;
            }
        }

        // ================= BUILD LIST =================
        var listToInsert = new List<SubjectFacultyEntity>();

        if (category == SubjectCategoryEnum.Theory || category == SubjectCategoryEnum.Both)
        {
            listToInsert.Add(new SubjectFacultyEntity
                {
                    SubjectSemesterId = model.SubjectSemesterId,
                    DivisionId = model.DivisionId,
                    FacultyId = theoryFacultyId,
                    TeachingType = SubjectCategoryEnum.Theory
                });
        }

        if (category == SubjectCategoryEnum.Practical || category == SubjectCategoryEnum.Both)
        {
            listToInsert.Add(new SubjectFacultyEntity
                {
                    SubjectSemesterId = model.SubjectSemesterId,
                    DivisionId = model.DivisionId,
                    FacultyId = practicalFacultyId == 0 ? theoryFacultyId : practicalFacultyId,
                    TeachingType = SubjectCategoryEnum.Practical
                });
        }

        // ================= EDIT =================
        if (isEditMode)
        {
            var existing = list.Where(x =>
                x.SubjectSemesterId == model.SubjectSemesterId &&
                x.DivisionId == model.DivisionId).ToList();

            foreach (var item in existing)
            {
                if (item.TeachingType == SubjectCategoryEnum.Theory)
                    item.FacultyId = theoryFacultyId;

                if (item.TeachingType == SubjectCategoryEnum.Practical)
                    item.FacultyId = practicalFacultyId == 0 ? theoryFacultyId : practicalFacultyId;

                await Repo.UpdateAsync(item);
            }

            await ShowToast("Updated successfully", "success");
        }
        else
        {
            var result = await Repo.BulkInsertAsync(listToInsert, Auth.UserId!.Value);
            await ShowToast(result.Item2, result.Item1 ? "success" : "danger");
        }

        list = await Repo.GetAllAsync();
        showManual = false;
    }
    async Task Toggle(int id)
    {
        await Repo.ToggleAsync(id);
        list = await Repo.GetAllAsync();

        await ShowToast("Status updated", "info");
    }

    void OnFileSelected(InputFileChangeEventArgs e) => file = e.File;

    async Task ProcessCsv()
    {
        if (file == null)
        {
            await ShowToast("Select CSV file", "danger");
            return;
        }

        if (courseId == 0 || semesterId == 0 || divisionId == 0)
        {
            await ShowToast("Select Course, Semester, Division first", "danger");
            return;
        }

        var userId = Auth.UserId!.Value;
        var finalList = new List<SubjectFacultyEntity>();

        var courseDeptId = courses.First(x => x.CourseId == courseId).DepartmentId;

        using var reader = new StreamReader(file.OpenReadStream());

        int row = 1;
        bool first = true;
        string? line;

        while ((line = await reader.ReadLineAsync()) != null)
        {
            if (first) { first = false; continue; }
            row++;

            if (string.IsNullOrWhiteSpace(line)) continue;

            // var data = line.Split(',');
            var data = line.Split(',', StringSplitOptions.TrimEntries);

            if (data.Length < 6)
            {
                await ShowToast($"Row {row}: Invalid column format", "danger");
                return;
            }

            var subjectName = data[2]?.Trim();
            var divisionName = data[3]?.Trim();
            var theoryEmail = data[4]?.Trim();
            var practicalEmail = data[5]?.Trim();

            var subject = subjectSemesters
                .FirstOrDefault(x => x.Subject.SubjectName == subjectName);

            if (subject == null)
            {
                await ShowToast($"Row {row}: Invalid Subject", "danger");
                return;
            }

            var division = divisions
                .FirstOrDefault(x => x.DivisionName == divisionName);

            if (division == null)
            {
                await ShowToast($"Row {row}: Invalid Division", "danger");
                return;
            }

            var category = subject.Subject.SubjectCategory;

            // ❌ BOTH EMPTY
            if (string.IsNullOrWhiteSpace(theoryEmail) && string.IsNullOrWhiteSpace(practicalEmail))
            {
                await ShowToast($"Row {row}: Faculty required", "danger");
                return;
            }

            // ❌ PRACTICAL ONLY
            if (string.IsNullOrWhiteSpace(theoryEmail) && !string.IsNullOrWhiteSpace(practicalEmail))
            {
                await ShowToast($"Row {row}: Theory faculty required first", "danger");
                return;
            }

            // 🔥 CATEGORY VALIDATION FIRST (FIXED)
            if (category == SubjectCategoryEnum.Theory && !string.IsNullOrWhiteSpace(practicalEmail))
            {
                await ShowToast($"Row {row}: Practical not allowed for Theory subject", "danger");
                return;
            }

            if (category == SubjectCategoryEnum.Practical && !string.IsNullOrWhiteSpace(theoryEmail))
            {
                await ShowToast($"Row {row}: Theory not allowed for Practical subject", "danger");
                return;
            }

            // 🔥 AUTO COPY ONLY FOR BOTH (FIXED)
            if (category == SubjectCategoryEnum.Both && string.IsNullOrWhiteSpace(practicalEmail))
            {
                practicalEmail = theoryEmail;
            }

            // ================= THEORY =================
            if (category == SubjectCategoryEnum.Theory || category == SubjectCategoryEnum.Both)
            {
                var theoryFaculty = await Repo.GetFacultyByEmail(theoryEmail);

                if (theoryFaculty == null)
                {
                    await ShowToast($"Row {row}: Invalid Theory Faculty", "danger");
                    return;
                }

                if (!await Repo.IsFacultyAllowed(theoryFaculty.FacultyId, courseDeptId))
                {
                    await ShowToast($"Row {row}: Theory faculty not allowed", "danger");
                    return;
                }

                finalList.Add(new SubjectFacultyEntity
                    {
                        SubjectSemesterId = subject.SubjectSemesterId,
                        DivisionId = division.DivisionId,
                        FacultyId = theoryFaculty.FacultyId,
                        TeachingType = SubjectCategoryEnum.Theory
                    });
            }

            // ================= PRACTICAL =================
            if (category == SubjectCategoryEnum.Practical || category == SubjectCategoryEnum.Both)
            {
                var practicalFaculty = await Repo.GetFacultyByEmail(practicalEmail);

                if (practicalFaculty == null)
                {
                    await ShowToast($"Row {row}: Invalid Practical Faculty", "danger");
                    return;
                }

                if (!await Repo.IsFacultyAllowed(practicalFaculty.FacultyId, courseDeptId))
                {
                    await ShowToast($"Row {row}: Practical faculty not allowed", "danger");
                    return;
                }

                finalList.Add(new SubjectFacultyEntity
                    {
                        SubjectSemesterId = subject.SubjectSemesterId,
                        DivisionId = division.DivisionId,
                        FacultyId = practicalFaculty.FacultyId,
                        TeachingType = SubjectCategoryEnum.Practical
                    });
            }
        }

        var result = await Repo.BulkInsertAsync(finalList, userId);

        if (result.Item1)
        {
            await ShowToast("CSV Uploaded Successfully", "success");
        }
        else
        {
            await ShowToast(result.Item2, "danger");
        }
        // 🔥 RESET AFTER SUCCESS
       
        list = await Repo.GetAllAsync();
        if (result.Item1)
        {
            courseId = 0;
            semesterId = 0;
            divisionId = 0;

            model = new SubjectFacultyEntity();   // 🔥 ADD THIS
            theoryFacultyId = 0;                  // 🔥 ADD
            practicalFacultyId = 0;               // 🔥 ADD

            subjectSemesters.Clear();
            divisions.Clear();

            showCsv = false;
        }
    }

   
    // async Task DownloadTemplate()
    // {
    //     var csv = "CourseName,SemesterNo,SubjectName,DivisionName,FacultyEmail\n";
    //     var bytes = Encoding.UTF8.GetBytes(csv);

    //     await JS.InvokeVoidAsync("downloadFile", "template.csv", bytes);
    // }

    async Task ShowToast(string msg, string type)
    {
        await JS.InvokeVoidAsync("showToast", msg, type);
    }
}