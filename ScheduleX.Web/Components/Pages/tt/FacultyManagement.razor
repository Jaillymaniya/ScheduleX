@page "/tt/faculty"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

@using ScheduleX.Core.Entities
@using ScheduleX.Core.Interfaces.TTCoordinator
@inject IFacultyRepository FacultyRepo

<h3 class="mb-4">Faculty Management</h3>

<div class="tt-card p-4 mb-4">

    <h5 class="mb-4">
        @(isEditMode ? "Edit Faculty" : "Add Faculty")
    </h5>

    <div class="row">

        <div class="col-md-6 mb-4">
            <label>Faculty Name</label>
            <input class="tt-input w-100"
                   @bind="model.FacultyName" />
        </div>

        <div class="col-md-6 mb-4">
            <label>Faculty Code</label>
            <input class="tt-input w-100"
                   @bind="model.FacultyCode" />
        </div>

        <div class="col-md-6 mb-4">
            <label>Email</label>
            <input class="tt-input w-100"
                   @bind="model.Email" />
        </div>

        <div class="col-md-6 mb-4">
            <label>Phone</label>
            <input class="tt-input w-100"
                   @bind="model.Phone" />
        </div>

        <div class="col-md-6 mb-4">
            <label>Department</label>
            <select class="tt-select w-100"
                    @bind="model.DepartmentId">
                <option value="0">-- Select Department --</option>
                @foreach (var dept in departments)
                {
                    <option value="@dept.DepartmentId">
                        @dept.DepartmentName
                    </option>
                }
            </select>
        </div>

        <div class="col-md-6 mb-4">
            <label>Max Lectures Per Day</label>
            <input type="number"
                   class="tt-input w-100"
                   @bind="model.MaxLecturesPerDay" />
        </div>

    </div>

    <div class="mt-3">
        <button class="btn btn-success me-2 px-4"
                @onclick="SaveFaculty">
            @(isEditMode ? "Update Faculty" : "Save Faculty")
        </button>

        @if (isEditMode)
        {
            <button class="btn btn-secondary px-4"
                    @onclick="CancelEdit">
                Cancel
            </button>
        }
    </div>

</div>

<hr />

<h5 class="mb-3">Faculty List</h5>

<div class="tt-card p-3">

    <table class="table table-dark table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Code</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Department</th>
                <th>Max Lectures</th>
                <th>Status</th>
                <th width="160">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var f in facultyList)
            {
                <tr class="@(f.IsActive ? "" : "opacity-50")">
                    <td>@f.FacultyName</td>
                    <td>@f.FacultyCode</td>
                    <td>@f.Email</td>
                    <td>@f.Phone</td>
                    <td>@f.Department?.DepartmentName</td>
                    <td>@f.MaxLecturesPerDay</td>
                    <td>@(f.IsActive ? "Active" : "Inactive")</td>
                    <td>
                        <button class="btn btn-sm btn-info me-1"
                                @onclick="() => EditFaculty(f)">
                            Edit
                        </button>

                        @if (f.IsActive)
                        {
                            <button class="btn btn-sm btn-danger"
                                    @onclick="() => SoftDelete(f.FacultyId)">
                                Deactivate
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-success"
                                    @onclick="() => ActivateFaculty(f.FacultyId)">
                                Activate
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

@code {

    private Faculty model = new();
    private List<Faculty> facultyList = new();
    private List<Department> departments = new();

    private bool isEditMode = false;

    protected override async Task OnInitializedAsync()
    {
        departments = await FacultyRepo.GetDepartmentsAsync();
        facultyList = await FacultyRepo.GetAllAsync();
    }

    private async Task SaveFaculty()
    {
        if (model.DepartmentId == 0)
            return;

        if (isEditMode)
            await FacultyRepo.UpdateAsync(model);
        else
            await FacultyRepo.AddAsync(model);

        model = new Faculty();
        isEditMode = false;

        facultyList = await FacultyRepo.GetAllAsync();
    }

    private void EditFaculty(Faculty faculty)
    {
        model = new Faculty
            {
                FacultyId = faculty.FacultyId,
                FacultyName = faculty.FacultyName,
                FacultyCode = faculty.FacultyCode,
                Email = faculty.Email,
                Phone = faculty.Phone,
                DepartmentId = faculty.DepartmentId,
                MaxLecturesPerDay = faculty.MaxLecturesPerDay,
                IsActive = faculty.IsActive
            };

        isEditMode = true;
    }

    private async Task SoftDelete(int id)
    {
        await FacultyRepo.SoftDeleteAsync(id);
        facultyList = await FacultyRepo.GetAllAsync();
    }

    private async Task ActivateFaculty(int id)
    {
        await FacultyRepo.ActivateAsync(id);
        facultyList = await FacultyRepo.GetAllAsync();
    }

    private void CancelEdit()
    {
        model = new Faculty();
        isEditMode = false;
    }
}