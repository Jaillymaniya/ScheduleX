    private class TemplatePreviewConfig
    {
        public string HeaderBg { get; set; } = "#1e293b";
        public string HeaderText { get; set; } = "#ffffff";
        public string BodyBg { get; set; } = "#ffffff";
        public string BodyText { get; set; } = "#111827";
        public string BorderColor { get; set; } = "#cbd5e1";
        public bool ShowRoom { get; set; } = true;
        public bool ShowFaculty { get; set; } = true;
        public bool ShowSubjectCode { get; set; } = true;
        public string CellPadding { get; set; } = "8px";
        public string FontSize { get; set; } = "14px";
    }

    private class PreviewSlot
    {
        public string Time { get; set; } = "";
        public string SubjectName { get; set; } = "";
        public string SubjectCode { get; set; } = "";
        public string FacultyName { get; set; } = "";
        public string RoomName { get; set; } = "";
        public bool IsBreak { get; set; }
    }

    private bool previewJsonInvalid = false;

    private TemplatePreviewConfig ParseTemplateJson(string? json)
    {
        previewJsonInvalid = false;

        if (string.IsNullOrWhiteSpace(json))
            return new TemplatePreviewConfig();

        try
        {
            var options = new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                };

            var parsed = JsonSerializer.Deserialize<TemplatePreviewConfig>(json, options);
            return parsed ?? new TemplatePreviewConfig();
        }
        catch
        {
            previewJsonInvalid = true;
            return new TemplatePreviewConfig();
        }
    }
    private string GetPreviewTableStyle()
    {
        var fontSize = previewConfig?.FontSize ?? "14px";
        return $"width:100%; border-collapse:collapse; font-size:{fontSize};";
    }

    private string GetPreviewHeaderStyle()
    {
        var headerBg = previewConfig?.HeaderBg ?? "#1e293b";
        var headerText = previewConfig?.HeaderText ?? "#ffffff";
        var borderColor = previewConfig?.BorderColor ?? "#cbd5e1";
        var cellPadding = previewConfig?.CellPadding ?? "8px";

        return $"background:{headerBg}; color:{headerText}; border:1px solid {borderColor}; padding:{cellPadding}; text-align:center;";
    }

    private string GetPreviewBodyStyle()
    {
        var bodyBg = previewConfig?.BodyBg ?? "#ffffff";
        var bodyText = previewConfig?.BodyText ?? "#111827";
        var borderColor = previewConfig?.BorderColor ?? "#cbd5e1";
        var cellPadding = previewConfig?.CellPadding ?? "8px";

        return $"background:{bodyBg}; color:{bodyText}; border:1px solid {borderColor}; padding:{cellPadding}; vertical-align:top; min-width:140px;";
    }
}