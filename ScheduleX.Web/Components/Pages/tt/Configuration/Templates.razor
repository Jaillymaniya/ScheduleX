@using System.Text.Json
@page "/tt/templates"
@layout ScheduleX.Web.Components.Layout.tt.TTLayout
@rendermode InteractiveServer

@using System.Net.Http.Json
@using ScheduleX.Web.DTOs
@inject HttpClient Http

<link href="css/templates.css" rel="stylesheet" />

<div class="template-page">
    <div class="template-header">
        <div>
            <h2>Timetable Templates</h2>
            <p>Manage timetable template designs for add, edit, view, soft delete and default selection.</p>
        </div>
        <button class="tt-btn tt-btn-primary" @onclick="OpenAddForm">+ Add Template</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="tt-alert tt-alert-success">@message</div>
    }

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="tt-alert tt-alert-danger">@error</div>
    }

    <div class="template-card">
        @if (loading)
        {
            <p>Loading templates...</p>
        }
        else if (templates == null || !templates.Any())
        {
            <p>No templates found.</p>
        }
        else
        {
            <table class="template-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Layout</th>
                        <th>Status</th>
                        <th>Default</th>
                        <th>Used In Batch</th>
                        <th>Created</th>
                        <th style="width:260px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in templates)
                    {
                        <tr>
                            <td>@item.TemplateName</td>
                            <td>@item.LayoutTypeName</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="status-badge active">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge inactive">Inactive</span>
                                }
                            </td>
                            <td>
                                @if (item.IsDefault)
                                {
                                    <span class="status-badge default">Default</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td>@item.UsedInBatchCount</td>
                            <td>@item.CreatedAt.ToString("dd-MM-yyyy")</td>
                            <td>
                                <div class="action-group">
                                    <button class="tt-btn tt-btn-sm" @onclick="() => ViewTemplate(item)">View</button>
                                    <button class="tt-btn tt-btn-sm tt-btn-warning" @onclick="() => EditTemplate(item)">Edit</button>

                                    @if (item.IsActive)
                                    {
                                        <button class="tt-btn tt-btn-sm tt-btn-info" @onclick="() => SetDefault(item.TemplateId)">Set Default</button>
                                        <button class="tt-btn tt-btn-sm tt-btn-danger" @onclick="() => SoftDelete(item.TemplateId)">Soft Delete</button>
                                    }
                                    else
                                    {
                                        <button class="tt-btn tt-btn-sm tt-btn-success" @onclick="() => Restore(item.TemplateId)">Restore</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (showForm)
    {
        <div class="template-modal-backdrop">
            <div class="template-modal">
                <div class="modal-header">
                    <h3>@(isEdit ? "Edit Template" : "Add Template")</h3>
                    <button class="close-btn" @onclick="CloseForm">×</button>
                </div>

                <div class="modal-body">
                    <div class="form-row">
                        <label>Template Name</label>
                        @if (isEdit)
                        {
                            <input class="form-control" @bind="form.TemplateName" />
                        }
                        else
                        {
                            <input class="form-control" @bind="createForm.TemplateName" />
                        }
                    </div>

                    <div class="form-row">
                        <label>Layout Type</label>
                        @if (isEdit)
                        {
                            <select class="form-control" @bind="form.LayoutType">
                                <option value="1">Grid</option>
                                <option value="2">Compact</option>
                                <option value="3">Detailed</option>
                            </select>
                        }
                        else
                        {
                            <select class="form-control" @bind="createForm.LayoutType">
                                <option value="1">Grid</option>
                                <option value="2">Compact</option>
                                <option value="3">Detailed</option>
                            </select>
                        }
                    </div>

                    <div class="form-row">
                        <label>Template JSON</label>
                        @if (isEdit)
                        {
                            <textarea class="form-control form-textarea" @bind="form.TemplateJson"></textarea>
                        }
                        else
                        {
                            <textarea class="form-control form-textarea" @bind="createForm.TemplateJson"></textarea>
                        }
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="tt-btn" @onclick="CloseForm">Cancel</button>
                    @if (isEdit)
                    {
                        <button class="tt-btn tt-btn-primary" @onclick="UpdateTemplate">Update</button>
                    }
                    else
                    {
                        <button class="tt-btn tt-btn-primary" @onclick="CreateTemplate">Save</button>
                    }
                </div>
            </div>
        </div>
    }

