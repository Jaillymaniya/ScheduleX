    @if (showView && selectedTemplate != null && previewConfig != null)
    {
        <div class="template-modal-backdrop">
            <div class="template-modal large preview-modal">
                <div class="modal-header">
                    <h3>View Template</h3>
                    <button class="close-btn" @onclick="CloseView">×</button>
                </div>

                <div class="modal-body">
                    <div class="view-grid">
                        <div><strong>Name:</strong> @selectedTemplate.TemplateName</div>
                        <div><strong>Layout:</strong> @selectedTemplate.LayoutTypeName</div>
                        <div><strong>Status:</strong> @(selectedTemplate.IsActive ? "Active" : "Inactive")</div>
                        <div><strong>Default:</strong> @(selectedTemplate.IsDefault ? "Yes" : "No")</div>
                        <div><strong>Used In Batch:</strong> @selectedTemplate.UsedInBatchCount</div>
                        <div><strong>Created:</strong> @selectedTemplate.CreatedAt.ToString("dd-MM-yyyy hh:mm tt")</div>
                    </div>

                    <div class="preview-section mt-3">
                        <label>Template Preview</label>

                        <div class="template-preview-box">
                            <table class="preview-table" style="@GetPreviewTableStyle()">
                                <thead>
                                    <tr>
                                        <th style="@GetPreviewHeaderStyle()">Time</th>
                                        @foreach (var day in previewDays)
                                        {
                                            <th style="@GetPreviewHeaderStyle()">@day</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var slot in previewSlots)
                                    {
                                        <tr>
                                            <td style="@GetPreviewBodyStyle()" class="time-cell">@slot.Time</td>

                                            @foreach (var day in previewDays)
                                            {
                                                <td style="@GetPreviewBodyStyle()">
                                                    @if (slot.IsBreak)
                                                    {
                                                        <div class="preview-break">Break</div>
                                                    }
                                                    else
                                                    {
                                                        <div class="preview-subject">@slot.SubjectName</div>

                                                        @if (previewConfig.ShowSubjectCode)
                                                        {
                                                            <div class="preview-meta">@slot.SubjectCode</div>
                                                        }

                                                        @if (previewConfig.ShowFaculty)
                                                        {
                                                            <div class="preview-meta">@slot.FacultyName</div>
                                                        }

                                                        @if (previewConfig.ShowRoom)
                                                        {
                                                            <div class="preview-meta">@slot.RoomName</div>
                                                        }
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="form-row mt-3">
                        <label>Template JSON</label>
                        <textarea class="form-control form-textarea" readonly>@selectedTemplate.TemplateJson</textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="tt-btn" @onclick="CloseView">Close</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<TimeTableTemplateDto> templates = new();
    private TimeTableTemplateDto? selectedTemplate;


    private bool loading = true;
    private bool showForm = false;
    private bool showView = false;
    private bool isEdit = false;

    private string? message;
    private string? error;

    private UpdateTimeTableTemplateDto form = new();
    private CreateTimeTableTemplateDto createForm = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTemplates();
    }

    private async Task LoadTemplates()
    {
        try
        {
            loading = true;
            error = null;
            message = null;

            var result = await Http.GetFromJsonAsync<List<TimeTableTemplateDto>>("api/tt/templates");
            templates = result ?? new List<TimeTableTemplateDto>();
        }
        catch (Exception ex)
        {
            error = $"Error loading templates: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void OpenAddForm()
    {
        isEdit = false;
        showForm = true;
        error = null;
        message = null;

        form = new UpdateTimeTableTemplateDto
            {
                LayoutType = 1,
                IsActive = true
            };

        createForm = new CreateTimeTableTemplateDto
            {
                LayoutType = 1
            };
    }

    private void EditTemplate(TimeTableTemplateDto item)
    {
        isEdit = true;
        showForm = true;
        error = null;
        message = null;

        form = new UpdateTimeTableTemplateDto
            {
                TemplateId = item.TemplateId,
                TemplateName = item.TemplateName,
                LayoutType = item.LayoutType,
                TemplateJson = item.TemplateJson,
                IsActive = item.IsActive
            };
    }

    // private void ViewTemplate(TimeTableTemplateDto item)
    // {
    //     selectedTemplate = item;
    //     showView = true;
    // }
    private void ViewTemplate(TimeTableTemplateDto item)
    {
        selectedTemplate = item;
        previewConfig = ParseTemplateJson(item.TemplateJson);
        showView = true;
    }

    private void CloseForm()
    {
        showForm = false;
    }

    private void CloseView()
    {
        showView = false;
        selectedTemplate = null;
        previewConfig = new TemplatePreviewConfig();
    }

    private async Task CreateTemplate()
    {
        try
        {
            error = null;
            message = null;

            var response = await Http.PostAsJsonAsync("api/tt/templates", createForm);
            var content = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                message = "Template created successfully.";
                showForm = false;
                await LoadTemplates();
            }
            else
            {
                error = content;
            }
        }
        catch (Exception ex)
        {
            error = $"Error creating template: {ex.Message}";
        }
    }

    private async Task UpdateTemplate()
    {
        try
        {
            error = null;
            message = null;

            var response = await Http.PutAsJsonAsync($"api/tt/templates/{form.TemplateId}", form);
            var content = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                message = "Template updated successfully.";
                showForm = false;
                await LoadTemplates();
            }
            else
            {
                error = content;
            }
        }
        catch (Exception ex)
        {
            error = $"Error updating template: {ex.Message}";
        }
    }

    private async Task SetDefault(int templateId)
    {
        try
        {
            error = null;
            message = null;

            var response = await Http.PutAsync($"api/tt/templates/{templateId}/set-default", null);
            var content = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                message = "Default template updated successfully.";
                await LoadTemplates();
            }
            else
            {
                error = content;
            }
        }
        catch (Exception ex)
        {
            error = $"Error setting default template: {ex.Message}";
        }
    }

    private async Task SoftDelete(int templateId)
    {
        try
        {
            error = null;
            message = null;

            var response = await Http.PutAsync($"api/tt/templates/{templateId}/soft-delete", null);
            var content = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                message = "Template soft deleted successfully.";
                await LoadTemplates();
            }
            else
            {
                error = content;
            }
        }
        catch (Exception ex)
        {
            error = $"Error deleting template: {ex.Message}";
        }
    }

    private async Task Restore(int templateId)
    {
        try
        {
            error = null;
            message = null;

            var response = await Http.PutAsync($"api/tt/templates/{templateId}/restore", null);
            var content = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                message = "Template restored successfully.";
                await LoadTemplates();
            }
            else
            {
                error = content;
            }
        }
        catch (Exception ex)
        {
            error = $"Error restoring template: {ex.Message}";
        }
    }
