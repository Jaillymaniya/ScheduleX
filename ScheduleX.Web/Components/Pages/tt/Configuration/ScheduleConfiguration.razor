@using ScheduleX.Core.Entities
@page "/tt/schedule-configuration"
@rendermode InteractiveServer
@layout ScheduleX.Web.Components.Layout.tt.TTLayout

<link href="css/schedule-config.css" rel="stylesheet" />

@using System.Net.Http.Json
@using ScheduleX.Web.DTOs
@inject HttpClient Http
@inject ScheduleX.Web.Services.AuthState Auth

<div class="schedule-page">

    <div class="schedule-header">
        <h2>Schedule Configuration</h2>
        
    </div>

    <div class="schedule-card">
    <h5>Schedule Settings</h5>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        @* <div class="alert alert-info">@message</div> *@
            <div class="schedule-alert schedule-alert-info">@message</div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        @* <div class="alert alert-danger">@errorMessage</div> *@
            <div class="schedule-alert schedule-alert-danger">@errorMessage</div>
    }

    <div class="row g-3">
        <div class="col-md-4">
                <label class="schedule-label">Allocated Course</label>
                <input class="schedule-input" value="@allocatedCourseName" readonly />
        </div>

        @* <div class="col-md-4"> *@
        @*     <label>Start Time</label> *@
            @*     <input type="time" class="schedule-input" @bind="model.StartTime" /> *@
        @* </div> *@

        @* <div class="col-md-4"> *@
        @*     <label>End Time</label> *@
            @*     <input type="time" class="schedule-input" @bind="model.EndTime" />  *@
        @* </div> *@
        <div class="col-md-4">
                <label class="schedule-label">Start Time</label>
                <input type="time" class="schedule-input"
                   value="@model.StartTime"
                   @onchange="OnStartTimeChanged" />
        </div>

        <div class="col-md-4">
                <label class="schedule-label">End Time</label>
                <input type="time" class="schedule-input"
                   value="@model.EndTime"
                   @onchange="OnEndTimeChanged" />
        </div>

        <div class="col-md-4">
                <label class="schedule-label">Lecture Duration (Min)</label>
                <input type="number" class="schedule-input" @bind="model.LectureDurationMin" min="1" />
        </div>

        <div class="col-md-4">
                <label class="schedule-label">Lectures Per Day</label>
                <input type="number" class="schedule-input" @bind="model.LecturesPerDay" min="1" />
        </div>

        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" @bind="model.IsActive" id="isActive" />
                <label class="form-check-label" for="isActive">Active</label>
            </div>
        </div>
    </div>

    <hr />

    <h6>Working Days</h6>
    <div class="row">
        <div class="col-md-12">
            @* <div class="d-flex flex-wrap gap-3"> *@
                <div class="schedule-checks">
                    <label class="schedule-label"><input type="checkbox" @bind="days.Mon" /> Monday</label>
                    <label class="schedule-label"><input type="checkbox" @bind="days.Tue" /> Tuesday</label>
                    <label class="schedule-label"><input type="checkbox" @bind="days.Wed" /> Wednesday</label>
                    <label class="schedule-label"><input type="checkbox" @bind="days.Thu" /> Thursday</label>
                    <label class="schedule-label"><input type="checkbox" @bind="days.Fri" /> Friday</label>
                    <label class="schedule-label"><input type="checkbox" @bind="days.Sat" /> Saturday</label>
                    <label class="schedule-label"><input type="checkbox" @bind="days.Sun" /> Sunday</label>
            </div>
        </div>
    </div>

    <div class="mt-3">
        @* <button class="btn btn-primary" @onclick="SaveConfig">Save Configuration</button> *@
            <button class="schedule-btn schedule-btn-primary" @onclick="SaveConfig">Save Configuration</button>

    </div>


        @if (model.ConfigId > 0)
        {
            <div class="schedule-card">
                <h5>Break Settings</h5>

                <div class="row g-3">
                    <div class="col-md-2">
                        <label class="schedule-label">Break No</label>
                        <input type="number" class="schedule-input" @bind="breakModel.BreakNo" min="1" />
                    </div>

                    <div class="col-md-3">
                        <label class="schedule-label">Break Name</label>
                        <input class="schedule-input" @bind="breakModel.BreakName" />
                    </div>

                    <div class="col-md-3">
                        <label class="schedule-label">After Lecture No</label>
                        <input type="number" class="schedule-input" @bind="breakModel.AfterLectureNo" min="1" />
                    </div>

                    <div class="col-md-2">
                        <label class="schedule-label">Break Duration</label>
                        <input type="number" class="schedule-input" @bind="breakModel.BreakDurationMin" min="1" />
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                        @if (!isEditingBreak)
                        {
                            <button class="schedule-btn schedule-btn-success w-100" @onclick="AddBreak">Add Break</button>
                        }
                        else
                        {
                            <div class="d-flex gap-2 w-100">
                                <button class="schedule-btn schedule-btn-success w-100" @onclick="UpdateBreak">Update</button>
                                <button class="schedule-btn schedule-btn-success w-100" @onclick="CancelBreakEdit">Cancel</button>
                            </div>
                        }
                    </div>
                </div>

                <div class="mt-3">
                    @* <table class="table table-bordered"> *@
                    <table class="schedule-table">
                        <thead>
                            <tr>
                                <th>Break No</th>
                                <th>Break Name</th>
                                <th>After Lecture</th>
                                <th>Duration</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (breaks.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center">No breaks added.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var b in breaks)
                                {
                                    <tr>
                                        <td>@b.BreakNo</td>
                                        <td>@b.BreakName</td>
                                        <td>@b.AfterLectureNo</td>
                                        <td>@b.BreakDurationMin min</td>
                                        <td class="d-flex gap-2">
                                            <button class="schedule-btn schedule-btn-primary" @onclick="() => EditBreak(b)">Edit</button>
                                            <button class="schedule-btn schedule-btn-danger" @onclick="() => DeleteBreak(b.BreakRuleId)">Delete</button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="schedule-card">
                <h5>Time Slot Preview</h5>
                <button class="schedule-btn schedule-btn-warning mb-3" @onclick="GenerateSlots">Generate Slots</button>

                @* <table class="table table-striped table-bordered"> *@
                <table class="schedule-table">
                    <thead>
                        <tr>
                            <th>Slot No</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                            <th>Type</th>
                            <th>Break Name</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (slots.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center">No slots generated.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var s in slots)
                            {
                                <tr>
                                    <td>@s.SlotNo</td>
                                    <td>@s.StartTime</td>
                                    <td>@s.EndTime</td>
                                    <td>@(s.SlotType == SlotTypeEnum.Lecture ? "Lecture" : "Break")</td>
                                    <td>@s.BreakName</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @* <div class="schedule-card"> *@
            @*     <h5>Template Selection</h5> *@
            @*     <p class="text-muted">This is for later timetable generation, not for ScheduleConfig save.</p> *@

            @*     <div class="row g-3"> *@
            @*         <div class="col-md-6"> *@
            @*             <label class="schedule-label">Select Template</label> *@
            @*             <select class="schedule-select" @bind="selectedTemplateId"> *@
            @*                 <option value="0">-- Select Template --</option> *@
            @*                 @foreach (var t in templates) *@
            @*                 { *@
            @*                     <option value="@t.TemplateId">@t.TemplateName (@GetLayoutName(t.LayoutType))</option> *@
            @*                 } *@
            @*             </select> *@
            @*         </div> *@
            @*     </div> *@
            @* </div> *@
        }

        @code {
            private void OnStartTimeChanged(ChangeEventArgs e)
            {
                model.StartTime = e.Value?.ToString() ?? "";
            }

            private void OnEndTimeChanged(ChangeEventArgs e)
            {
                model.EndTime = e.Value?.ToString() ?? "";
            }

            private ScheduleConfigDto model = new()
        {
            StartTime = "09:00",
            EndTime = "14:00",
            LectureDurationMin = 60,
            LecturesPerDay = 5,
            IsActive = true
        };

            private BreakRuleDto breakModel = new();
            private List<BreakRuleDto> breaks = new();
            private List<TimeSlotDto> slots = new();
            private List<TemplateDto> templates = new();

            private string allocatedCourseName = "";
            private int allocatedCourseId = 0;
            private int allocatedDepartmentId = 0;
            private int selectedTemplateId = 0;

            private bool isEditingBreak = false;
            private int editingBreakId = 0;

            private string? message;
            private string? errorMessage;

            private WorkingDaysVm days = new();

            protected override async Task OnInitializedAsync()
            {
                await LoadAllocatedCourse();
                await LoadTemplates();

                if (allocatedCourseId > 0)
                {
                    await LoadExistingConfig();
                }
            }

            private async Task LoadAllocatedCourse()
            {
                try
                {
                    // change this endpoint if your existing TT course API is different
                    var course = await Http.GetFromJsonAsync<MyCourseVm>($"api/tt/course/my-course/{Auth.UserId}");
                    if (course != null)
                    {
                        allocatedCourseId = course.CourseId;
                        allocatedCourseName = course.CourseName ?? "";
                        allocatedDepartmentId = course.DepartmentId;
                    }
                }
                catch (Exception ex)
                {
                    errorMessage = $"Unable to load allocated course. {ex.Message}";
                }
            }

            private async Task LoadExistingConfig()
            {
                try
                {
                    var data = await Http.GetFromJsonAsync<ScheduleConfigDto>($"api/tt/schedule-config/by-course/{allocatedCourseId}");
                    if (data != null)
                    {
                        model = data;
                        breaks = data.BreakRules ?? new();
                        ApplyWorkingDaysMask(model.WorkingDaysMask);

                        if (model.ConfigId > 0)
                        {
                            var loadedSlots = await Http.GetFromJsonAsync<List<TimeSlotDto>>($"api/tt/schedule-config/slots/{model.ConfigId}");
                            slots = loadedSlots ?? new();
                        }
                    }
                    else
                    {
                        model.CourseId = allocatedCourseId;
                        model.DepartmentId = allocatedDepartmentId;
                    }
                }
                catch
                {
                    errorMessage = "Unable to load existing configuration.";
                }
            }

            private async Task LoadTemplates()
            {
                try
                {
                    templates = await Http.GetFromJsonAsync<List<TemplateDto>>("api/tt/schedule-config/templates") ?? new();
                    var defaultTemplate = templates.FirstOrDefault(x => x.IsDefault);
                    if (defaultTemplate != null)
                        selectedTemplateId = defaultTemplate.TemplateId;
                }
                catch
                {
                    templates = new();
                }
            }

            private async Task SaveConfig()
            {
                try
                {
                    errorMessage = null;
                    message = null;

                    model.CourseId = allocatedCourseId;
                    model.DepartmentId = allocatedDepartmentId;
                    model.WorkingDaysMask = GetWorkingDaysMask();

                    if (model.CourseId <= 0)
                    {
                        errorMessage = "Allocated course is missing.";
                        return;
                    }

                    if (model.DepartmentId <= 0)
                    {
                        errorMessage = "Allocated department is missing.";
                        return;
                    }

                    var response = await Http.PostAsJsonAsync("api/tt/schedule-config/save", model);

                    if (!response.IsSuccessStatusCode)
                    {
                        errorMessage = await response.Content.ReadAsStringAsync();
                        return;
                    }

                    var saved = await response.Content.ReadFromJsonAsync<ScheduleConfigDto>();
                    if (saved != null)
                    {
                        model = saved;
                        await LoadExistingConfig();
                        message = "Configuration saved successfully.";
                    }
                }
                catch (Exception ex)
                {
                    errorMessage = ex.Message;
                }
            }

            private async Task AddBreak()
            {
                try
                {
                    errorMessage = null;
                    message = null;

                    breakModel.ConfigId = model.ConfigId;

                    var response = await Http.PostAsJsonAsync("api/tt/schedule-config/breaks", breakModel);

                    if (!response.IsSuccessStatusCode)
                    {
                        errorMessage = await response.Content.ReadAsStringAsync();
                        return;
                    }

                    breakModel = new BreakRuleDto();
                    await ReloadBreaks();
                    await GenerateSlots();
                    message = "Break added successfully.";
                }
                catch (Exception ex)
                {
                    errorMessage = ex.Message;
                }
            }

            private void EditBreak(BreakRuleDto b)
            {
                breakModel = new BreakRuleDto
            {
                BreakRuleId = b.BreakRuleId,
                ConfigId = b.ConfigId,
                BreakNo = b.BreakNo,
                BreakName = b.BreakName,
                AfterLectureNo = b.AfterLectureNo,
                BreakDurationMin = b.BreakDurationMin
            };

                isEditingBreak = true;
                editingBreakId = b.BreakRuleId;
            }

            private async Task DeleteBreak(int breakRuleId)
            {
                try
                {
                    var response = await Http.DeleteAsync($"api/tt/schedule-config/breaks/{breakRuleId}");
                    if (!response.IsSuccessStatusCode)
                    {
                        errorMessage = "Unable to delete break.";
                        return;
                    }

                    await ReloadBreaks();
                    await GenerateSlots();
                    message = "Break deleted successfully.";
                }
                catch (Exception ex)
                {
                    errorMessage = ex.Message;
                }
            }

            private async Task UpdateBreak()
            {
                try
                {
                    errorMessage = null;
                    message = null;

                    breakModel.ConfigId = model.ConfigId;
                    breakModel.BreakRuleId = editingBreakId;

                    var response = await Http.PutAsJsonAsync($"api/tt/schedule-config/breaks/{breakModel.BreakRuleId}", breakModel);

                    if (!response.IsSuccessStatusCode)
                    {
                        errorMessage = await response.Content.ReadAsStringAsync();
                        return;
                    }

                    breakModel = new BreakRuleDto();
                    isEditingBreak = false;
                    editingBreakId = 0;

                    await ReloadBreaks();
                    await GenerateSlots();

                    message = "Break updated successfully.";
                }
                catch (Exception ex)
                {
                    errorMessage = ex.Message;
                }
            }

            private void CancelBreakEdit()
            {
                breakModel = new BreakRuleDto();
                isEditingBreak = false;
                editingBreakId = 0;
            }

            private async Task ReloadBreaks()
            {
                breaks = await Http.GetFromJsonAsync<List<BreakRuleDto>>($"api/tt/schedule-config/breaks/{model.ConfigId}") ?? new();
            }

            private async Task GenerateSlots()
            {
                try
                {
                    errorMessage = null;
                    message = null;

                    var response = await Http.PostAsync($"api/tt/schedule-config/generate-slots/{model.ConfigId}", null);

                    if (!response.IsSuccessStatusCode)
                    {
                        errorMessage = await response.Content.ReadAsStringAsync();
                        return;
                    }

                    slots = await response.Content.ReadFromJsonAsync<List<TimeSlotDto>>() ?? new();
                    message = "Time slots generated successfully.";
                }
                catch (Exception ex)
                {
                    errorMessage = ex.Message;
                }
            }

            private int GetWorkingDaysMask()
            {
                int mask = 0;
                if (days.Mon) mask |= 1;
                if (days.Tue) mask |= 2;
                if (days.Wed) mask |= 4;
                if (days.Thu) mask |= 8;
                if (days.Fri) mask |= 16;
                if (days.Sat) mask |= 32;
                if (days.Sun) mask |= 64;
                return mask;
            }

            private void ApplyWorkingDaysMask(int mask)
            {
                days.Mon = (mask & 1) == 1;
                days.Tue = (mask & 2) == 2;
                days.Wed = (mask & 4) == 4;
                days.Thu = (mask & 8) == 8;
                days.Fri = (mask & 16) == 16;
                days.Sat = (mask & 32) == 32;
                days.Sun = (mask & 64) == 64;
            }

            // private string GetLayoutName(byte layoutType) => layoutType switch
            // {
            //     1 => "Grid",
            //     2 => "Compact",
            //     3 => "Detailed",
            //     _ => "Unknown"
            // };

            private string GetLayoutName(LayoutTypeEnum layoutType) => layoutType switch
            {
                LayoutTypeEnum.Grid => "Grid",
                LayoutTypeEnum.Compact => "Compact",
                LayoutTypeEnum.Detailed => "Detailed",
                _ => "Unknown"
            };

            public class WorkingDaysVm
            {
                public bool Mon { get; set; }
                public bool Tue { get; set; }
                public bool Wed { get; set; }
                public bool Thu { get; set; }
                public bool Fri { get; set; }
                public bool Sat { get; set; }
                public bool Sun { get; set; }
            }

            public class MyCourseVm
            {
                public int CourseId { get; set; }
                public int DepartmentId { get; set; }
                public string? CourseName { get; set; }
            }
        }
     
    </div>
</div>
