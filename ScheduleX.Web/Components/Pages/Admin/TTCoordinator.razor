@page "/admin/ttcoordinator"
@layout ScheduleX.Web.Components.Layout.Admin.AdminLayout
@using ScheduleX.Web.Services.Admin
@using ScheduleX.Web.DTOs
@using ScheduleX.Core.Entities
@inject TTCoordinatorApiService Service
<link href="css/ttcoordinator.css" rel="stylesheet" />
<div class="tt-container">

    <!-- TOP BUTTON -->
    <div class="header-section">

        <div class="search-container">
            <input type="text"
                   class="search-input"
                   placeholder="Search by name, username or email..." />
        </div>

        <button class="btn-main"
                @onclick="ToggleForm">
            + @(showForm ? "Close Form" : "Register Coordinator")
        </button>

    </div>
    @if (showToast)
    {
        <div class="toast-container">
            <div class="toast-box">
                <div class="toast-content">
                    @toastMessage
                </div>
                <div class="toast-progress"></div>
            </div>
        </div>
    }
    <!-- REGISTRATION FORM (VISIBLE ONLY WHEN BUTTON CLICKED) -->
    <!-- REGISTRATION FORM (VISIBLE ONLY WHEN BUTTON CLICKED) -->
    @if (showForm)
    {
        <div class="tt-card">
            <EditForm Model="model" OnValidSubmit="Register">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-grid">
                    <div class="form-group">
                        <label>Full Name <span>*</span></label>
                        <InputText class="form-input" @bind-Value="model.FullName" placeholder="Enter full name" />
                    </div>

                    <div class="form-group">
                        <label>Username <span>*</span></label>
                        <InputText class="form-input" @bind-Value="model.Username" placeholder="Enter username" />
                    </div>

                    <div class="form-group">
                        <label>Email <span>*</span></label>
                        <InputText class="form-input" @bind-Value="model.Email" placeholder="Enter email address" type="email" />
                    </div>

                    <div class="form-group">
                        <label>Phone <span>*</span></label>
                        <InputText class="form-input" @bind-Value="model.Phone" placeholder="Enter phone number" />
                    </div>

                    <div class="form-group">
                        <label>Password <span>*</span></label>
                        <InputText class="form-input"
                                   type="password"
                                   @bind-Value="model.Password"
                                   placeholder="Enter password" />
                    </div>

                    <div class="form-group">
                        <label>Department <span>*</span></label>
                        <InputSelect class="form-input"
                                     @bind-Value="model.DepartmentId"
                                     @bind-Value:after="LoadCourses">
                            <option value="">Select Department</option>
                            @foreach (var d in departments)
                            {
                                <option value="@d.DepartmentId">@d.DepartmentName</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-group">
                        <label>Course <span>*</span></label>
                        <InputSelect class="form-input"
                                     @bind-Value="model.CourseId"
                                     disabled="@(courses.Count == 0)">
                            <option value="">Select Course</option>
                            @foreach (var c in courses)
                            {
                                <option value="@c.CourseId">@c.CourseName</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <button type="submit" class="btn-register">
                    Save Coordinator
                </button>
            </EditForm>
        </div>
    }
