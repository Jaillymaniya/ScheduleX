    <!-- LIST BELOW -->
    <!-- ACTIVE COORDINATORS -->
    <div class="tt-list-card">

        <h3>Active TT Coordinators
            <span class="count-badge">@activeCoordinators.Count</span>
        </h3>

        @if (activeCoordinators.Count == 0)
        {
            <p class="no-record">No active coordinators found.</p>
        }
        else
        {
            <table class="tt-table">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Department</th>
                        <th>Course</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in activeCoordinators)
                    {
                        <tr>
                            <td>@u.FullName</td>
                            <td>@u.Username</td>
                            <td>@u.Department?.DepartmentName</td>
                            <td>@u.TTCoordinatorCourses.FirstOrDefault()?.Course?.CourseName</td>
                            <td>@u.Email</td>
                            <td>@u.Phone</td>
                            <td>
                                <button class="btn-deactivate"
                                        @onclick="() => ToggleStatus(u.UserId, false)">
                                    Deactivate
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- INACTIVE COORDINATORS -->
    <div class="tt-list-card mt-4">

        <h3>Inactive TT Coordinators
            <span class="count-badge inactive">@inactiveCoordinators.Count</span>
        </h3>

        @if (inactiveCoordinators.Count == 0)
        {
            <p class="no-record">No inactive coordinators found.</p>
        }
        else
        {
            <table class="tt-table">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Department</th>
                        <th>Course</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in inactiveCoordinators)
                    {
                        <tr class="inactive-row">
                            <td>@u.FullName</td>
                            <td>@u.Username</td>
                            <td>@u.Department?.DepartmentName</td>
                            <td>@u.TTCoordinatorCourses.FirstOrDefault()?.Course?.CourseName</td>
                            <td>@u.Email</td>
                            <td>@u.Phone</td>
                            <td>
                                <button class="btn-activate"
                                        @onclick="() => ToggleStatus(u.UserId, true)">
                                    Activate
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

</div>

@code {

    RegisterTTCoordinatorDto model = new();
    // List<User> coordinators = new();
    List<User> activeCoordinators = new();
    List<User> inactiveCoordinators = new();
    List<Department> departments = new();
    List<Course> courses = new();

    bool showForm = false;
    bool showToast = false;
    string toastMessage = "";
    async Task LoadData()
    {
        var all = await Service.GetAllAsync();

        activeCoordinators = all.Where(x => x.IsActive).ToList();
        inactiveCoordinators = all.Where(x => !x.IsActive).ToList();
    }
    protected override async Task OnInitializedAsync()
    {
        // coordinators = await Service.GetAllAsync();
        await LoadData();
        departments = await Service.GetDepartmentsAsync();
    }
    async Task ShowToast(string message)
    {
        toastMessage = message;
        showToast = true;
        StateHasChanged();

        await Task.Delay(3000);

        showToast = false;
        StateHasChanged();
    }
    void ToggleForm()
    {
        showForm = !showForm;

        if (showForm)
        {
            model = new RegisterTTCoordinatorDto();
            courses.Clear();
        }
    }

   
    async Task Register()
    {
        try
        {
            await Service.RegisterAsync(model);

            await LoadData();

            await ShowToast("Coordinator Registered Successfully");

            model = new RegisterTTCoordinatorDto();
            courses.Clear();
        }
        catch (Exception ex)
        {
            await ShowToast(ex.Message);
        }
    }
    async Task LoadCourses()
    {
        if (model.DepartmentId.HasValue)
            courses = await Service.GetCoursesAsync(model.DepartmentId.Value);
        else
            courses.Clear();

        model.CourseId = null;
    }

    
    async Task ToggleStatus(int id, bool activate)
    {
        await Service.ToggleAsync(id);

        await LoadData();

        await ShowToast(
            activate
                ? "Coordinator Activated Successfully"
                : "Coordinator Deactivated Successfully"
        );
    }
}
