@inherits LayoutComponentBase
@inject ScheduleX.Web.Services.AuthState Auth
@inject NavigationManager Nav

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<link rel="stylesheet" href="css/tt.css" />
<link rel="stylesheet" href="/css/faculty.css" />
<link href="/css/Semesters.css" rel="stylesheet" />
<link rel="stylesheet" href="/css/subject-mapping.css" />
<link rel="stylesheet" href="/css/subjectfaculty.css" />
<link rel="stylesheet" href="/css/subject.css?v=2.0" />
<link rel="stylesheet" href="/css/subject-semester.css" />
<link href="/css/schedule-config.css" rel="stylesheet" />
<link href="/css/templates.css" rel="stylesheet" />
<link href="/css/room.css" rel="stylesheet" />
<link href="/css/room.css" rel="stylesheet" />
@code{
    protected override void OnInitialized()
    {
        // If user is not logged in, block TT pages
        if (!Auth.IsLoggedIn)
        {
            // replace:true clears back history entry
            Nav.NavigateTo("/login", replace: true);
        }
    }
}

<div class="tt-shell">
    <div class="tt-sidebar">
        <TTSidebar />
    </div>

    <div class="tt-main">
        <div class="tt-topbar">
            <TTTopbar />
        </div>

        <main class="tt-content">
            @Body
        </main>
    </div>
</div>